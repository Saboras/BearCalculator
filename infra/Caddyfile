# Kingdom 1516 — Caddy edge config (Story 3.1 / AC3, NFR-10).
#
# Caddy is the single public surface: it serves the static Astro site on the apex
# domain and reverse-proxies Directus (Studio/API) on a dedicated admin subdomain.
# Directus is NEVER exposed directly (AR-5 / AD-3) — this file is the only route to it.
#
# Domains are env-var seams (Open Q1, deferred) with obviously-fake defaults injected
# from infra/.env. A real domain is a launch blocker, not a build blocker: auto-HTTPS
# goes live the moment a real domain points at the host.

{
	email {$CADDY_ACME_EMAIL}
}

# Security headers on every response. Caddy's auto-HTTPS redirects HTTP→HTTPS but
# does NOT emit HSTS on its own; both hosts set it explicitly (no includeSubDomains —
# each host carries its own header, a future non-TLS subdomain must not break).
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

# Public static site — Astro dist/ rsynced to /srv/site by CI (read-only mount).
{$SITE_DOMAIN} {
	import security_headers
	root * /srv/site
	encode zstd gzip
	file_server
}

# Admin subdomain — the ONLY path to Directus, over auto-HTTPS.
{$DIRECTUS_DOMAIN} {
	import security_headers
	reverse_proxy directus:8055
}
