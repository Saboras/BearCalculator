# Kingdom 1516 backend — environment template (Story 3.1).
#
# Copy to infra/.env on the HOST ONLY and fill in real values. infra/.env is
# git-ignored and must never be committed. Most defaults are deliberately fake so they
# fail loudly if they ever reach production — the ONE exception is ADMIN_EMAIL, which must be a
# validator-valid address for the first-run bootstrap to work (see the ADMIN section below).

# --- Directus secrets (host-only) ---
# SECRET signs access/refresh tokens. Directus 12 needs only SECRET (no legacy KEY).
# Generate a strong random value on the host, e.g. `openssl rand -hex 32`.
SECRET=dev-only-not-for-prod-change-me

# First-run admin bootstrap ONLY. After the first `docker compose up`, change the
# password in the Studio and remove ADMIN_PASSWORD from infra/.env (see README).
# admin@example.com is the RFC-2606 example domain — obviously fake, and (unlike the
# reserved .invalid TLD) accepted by Directus 12's email validator, so first-run
# bootstrap actually creates the admin. ⚠ Unlike the other placeholders this is a WORKING
# login (admin@example.com / changeme): set a REAL ADMIN_EMAIL and a strong ADMIN_PASSWORD on
# the host BEFORE the first boot on any public/internet-facing box.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Externally reachable admin URL (the Caddy admin subdomain, trailing slash).
# A wrong value breaks the Studio behind the proxy — keep it in sync with DIRECTUS_DOMAIN.
PUBLIC_URL=https://admin.kingdom1516.example/

# --- Domains (Open Q1 — placeholder until a real domain is procured) ---
# SITE_DOMAIN also drives the leader-auth CORS + session-cookie config on the
# Directus service (Story 3.2): CORS_ORIGIN=https://$SITE_DOMAIN and the parent-domain
# session cookie .$SITE_DOMAIN. No new secret — the auth cookie behavior derives from
# these domains. Keep SITE_DOMAIN and DIRECTUS_DOMAIN as apex + its subdomain (same-site).
SITE_DOMAIN=kingdom1516.example
DIRECTUS_DOMAIN=admin.kingdom1516.example
CADDY_ACME_EMAIL=ops@kingdom1516.example
