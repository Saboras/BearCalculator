# Kingdom 1516 frontend — environment template (Story 3.2).
#
# Copy to site/.env locally and set the real value; site/.env is git-ignored and
# must never be committed. This default is deliberately fake so it fails loudly if
# it ever reaches a live build.
#
# PUBLIC_DIRECTUS_URL is the leader-auth API base (the Caddy admin subdomain, https).
# It is PUBLIC (baked into client JS, not a secret). Astro exposes PUBLIC_* vars to
# the browser via import.meta.env — see src/lib/directus.ts. `npm run build` is green
# with this placeholder; the real value is a LAUNCH blocker (Open Q1 domain), not a
# build blocker, and must equal the live DIRECTUS_DOMAIN or CORS/login breaks.
# It is also the base URL for the build-time Finder read (Story 4.3).
PUBLIC_DIRECTUS_URL=https://admin.kingdom1516.example

# DIRECTUS_TOKEN is the read-only STATIC token the BUILD uses to pull the alliances
# collection at build time (Story 4.3 / AR-18). It is a SECRET and is deliberately
# NOT prefixed PUBLIC_ — Astro v6 keeps non-PUBLIC_ vars in process.env only, never
# in the client bundle (see src/lib/directus-build.ts). Set it as a GitHub Actions
# secret for CI and in site/.env locally. With this fake placeholder (or unset) the
# build sources the committed src/data/alliances.json seed instead and stays GREEN —
# a real token switches the Finder to live Directus data. Mint it on a read-only
# Directus user whose policy grants read on `alliances` (see infra/roles-and-policies.md).
DIRECTUS_TOKEN=REPLACE_WITH_READ_ONLY_BUILD_TOKEN
