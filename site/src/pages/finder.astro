---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import TimezoneRow from '../components/TimezoneRow.astro';
import PeakWindows from '../components/PeakWindows.astro';
import AllianceCard from '../components/AllianceCard.astro';
import { alliances } from '../data/alliances';

const allianceCount = alliances.length;
---

<Layout title="Kingdom 1516 — Alliance Finder">
  <main class="finder">
    {/*
      Skeleton marker — render-blocking, mirrors the no-FOUC theme init in
      Layout.astro. Sets a root flag the instant JS can run so the result cards
      show a brief skeleton during the client-side UTC→local resolve; the finder
      script clears it right after render(). No JS → flag never set → the rule
      never matches → real (honest UTC) cards show immediately, never a frozen
      shimmer. (AC1; no-JS safety.)
    */}
    <script is:inline>document.documentElement.dataset.finderResolving = '';</script>

    <header class="finder-head">
      <div class="ribbon"><span class="ribbon-band">Alliance Finder</span></div>
      <h1>Find the alliance that fits your evening.</h1>
      <p class="lead" id="finder-lead">Ranked by your local time — best fit first.</p>
    </header>

    <TimezoneRow />

    <PeakWindows />

    <p class="reassure">
      <span class="reassure-ic" aria-hidden="true"><Icon name="check" /></span>These are recommendations.
    </p>

    <section class="results" aria-label="Alliance recommendations">
      {/*
        Zero / empty-dataset state (AC4). An empty alliances.json is a valid build
        state — render plainly and still route to Apply (never dead-end). The
        generic Apply button carries NO data-slug/name (no alliance to pre-fill);
        the contract is Story 2.4, so it keeps the /join placeholder. The result
        <ol> stays in the DOM but renders empty, so the client script's element
        lookups still resolve safely.
      */}
      {allianceCount === 0 ? (
        <div class="zero-state">
          <span class="zero-ic" aria-hidden="true"><Icon name="building-2" /></span>
          <div class="zero-text">
            <p class="zero-head">No alliances are listed yet.</p>
            <p class="zero-sub">You can still apply to transfer — we'll help you find a fitting alliance once the list is in.</p>
          </div>
          <div class="ac-foot">
            <a class="btn-gold" href="/join">Apply to transfer</a>
            <span class="prefill-note">You can pick your alliance later.</span>
          </div>
        </div>
      ) : (
        <div class="section-head">
          <h2>Your best matches</h2>
          <span class="count" id="result-count">
            {allianceCount} {allianceCount === 1 ? 'alliance' : 'alliances'} · times shown in UTC
          </span>
        </div>
      )}

      {/*
        No-good-match banner (AC2) — hidden until the client render() finds no
        Great/Good fit for this timezone, then revealed ABOVE the still-rendered,
        still-appliable Stretch cards. Re-evaluated on every render (tz change).
      */}
      {allianceCount > 0 && (
        <div class="empty-banner" id="empty-banner" hidden>
          <span class="empty-ic" aria-hidden="true"><Icon name="moon" /></span>
          <div class="empty-text">
            <p class="empty-head">No alliance lands squarely in your evening — here are the closest.</p>
            <p class="empty-sub">None of our Major alliances peak during your evening right now. These are the nearest stretch matches, so you still have a place to start.</p>
          </div>
        </div>
      )}

      <ol class="result-list" id="result-list">
        {alliances.map((a) => <AllianceCard alliance={a} />)}
      </ol>
    </section>
  </main>
</Layout>

<script src="../scripts/finder/index.ts"></script>

<style>
  /*
    Finder page shell only — the section layout, heading/ribbon, results header,
    no-match banner, and zero-state. The tz row, peak windows, and result card
    each carry their own markup + scoped style in their component; the gold Apply
    button is the shared global .btn-gold recipe (global.css).
  */
  .finder {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-9);
  }

  /* ===== Heading + ribbon (recipe mirrors Home) ===== */
  .finder-head {
    position: relative;
    text-align: center;
    padding: var(--space-5) var(--space-4) 0;
  }
  .ribbon {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .ribbon::before,
  .ribbon::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 54px;
    height: 16px;
    background: var(--color-primary);
    transform: translateY(-50%);
    box-shadow: 0 2px 4px rgba(44, 38, 34, .2);
    display: none; /* desktop-only ornament; shown at 768px (see breakpoint) */
  }
  .ribbon::before {
    left: -66px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 12px 50%);
  }
  .ribbon::after {
    right: -66px;
    clip-path: polygon(0 0, 100% 0, calc(100% - 12px) 50%, 100% 100%, 0 100%);
  }
  .ribbon-band {
    display: inline-block;
    background: linear-gradient(#E8A149, #E08A2B);
    color: var(--color-primary-foreground);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(224, 138, 43, .35), inset 0 1px 0 rgba(255, 255, 255, .4);
    text-shadow: 0 1px 1px rgba(44, 38, 34, .3);
  }
  .finder-head h1 {
    font-size: clamp(24px, 6vw, 34px);
    line-height: 1.1;
    max-width: 560px;
    margin: var(--space-4) auto var(--space-2);
    color: var(--color-ink);
  }
  .finder-head .lead {
    color: var(--color-muted);
    font-size: 15px;
    margin: 0;
  }

  /* ===== Reassurance (AC5 — above results; repeated near Apply via prefill note) ===== */
  .reassure {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-2) 0 var(--space-5);
    font-size: 13px;
    color: var(--color-muted);
  }
  .reassure-ic {
    color: var(--color-accent);
    display: inline-flex;
  }

  /* ===== Section head ===== */
  .section-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin: 0 0 var(--space-4);
  }
  .section-head h2 {
    font-size: 18px;
    margin: 0;
    color: var(--color-ink);
  }
  .section-head .count {
    font-size: 12px;
    color: var(--color-muted);
    font-weight: 600;
  }

  /* ===== Result list ===== */
  .result-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* ===== Zero-state Apply foot (shares the gold button + note layout with the
     card, but the card is a separate component — Rule of Three says duplicate
     these two tiny rules rather than extract at the 2nd use). ===== */
  .ac-foot {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }
  .prefill-note {
    font-size: 11.5px;
    color: var(--color-muted);
  }

  /* ===== No-good-match empty banner (AC2) — soft signal (dashed gold), never an
     error. Revealed client-side above the still-appliable Stretch cards. ===== */
  .empty-banner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background: linear-gradient(#FDF6E8, #F6ECD4);
    border: 1px dashed var(--color-primary);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-5);
    margin: 0 0 var(--space-4);
  }
  .empty-banner[hidden] {
    display: none;
  }
  .empty-ic {
    flex: none;
    margin-top: 2px;
    font-size: 20px;
    color: var(--color-primary-hover);
    display: inline-flex;
  }
  /* Running text, not a display heading — Inter bold, never Lilita One (so NOT an
     <h*>, which global.css maps to the display face). */
  .empty-head {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 var(--space-1);
  }
  .empty-sub {
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-muted);
    margin: 0;
  }

  /* ===== Zero / empty-dataset state (AC4) — plain, still routes to Apply ===== */
  .zero-state {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    background: linear-gradient(180deg, #FDF9EF, #F8EFD8);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card);
    padding: var(--space-6) var(--space-5);
  }
  .zero-ic {
    font-size: 24px;
    color: var(--color-primary-hover);
    display: inline-flex;
  }
  .zero-head {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-ink);
    margin: 0 0 var(--space-1);
  }
  .zero-sub {
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--color-muted);
    margin: 0;
  }
  .zero-state .ac-foot {
    margin-top: var(--space-2);
  }

  /* ===== Desktop enhancement (single 768px breakpoint, mirrors the shell) ===== */
  @media (min-width: 768px) {
    .ribbon::before,
    .ribbon::after {
      display: block;
    }
  }

  /* ===== Mobile: full-width prefill note under the stacked Apply button ===== */
  @media (max-width: 767.98px) {
    .prefill-note {
      width: 100%;
      text-align: center;
    }
  }

  /* ===== Dark "Royal Court" — the baked light gradients need dark variants
     (the Story 1.3/1.4 wash-out guard). ===== */
  :global(:root[data-theme="dark"]) .ribbon-band {
    background: linear-gradient(#F2A93B, #E0962A);
    text-shadow: none;
  }
  :global(:root[data-theme="dark"]) .empty-banner,
  :global(:root[data-theme="dark"]) .zero-state {
    background: linear-gradient(var(--color-surface), var(--color-bg));
  }
</style>
