---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import alliancesData from '../data/alliances.json';

/*
  The Alliance type lives here, with its first consumer — NOT in src/lib/, which
  is reserved for MVP-2 Directus (Story 1.5 lock). 7 canonical fields (AD-18); the
  same flat shape both phases. Times are "HH:MM" UTC times-of-day (no date), peak
  is a single scalar (never a range), and every time field is nullable (AD-10).
*/
interface Alliance {
  name: string;
  slug: string;
  bear_trap_1: string | null;
  bear_trap_2: string | null;
  peak: string | null;
  farm_alliance: string | null;
  official: string | null;
}

/*
  Build-time validation (AC6). A malformed time, a duplicate slug, or a non-canonical
  row must fail `npm run build` loudly instead of rendering wrong. This is the data
  file's first consumer — Story 2.1 shipped it unchecked and handed the gate here.

  An explicit check (not a schema lib) is the KISS choice: this is trusted, static,
  hand-authored data, so the "use schema validation" convention — which targets
  untrusted runtime HTTP boundaries — does not apply. A thrown error in Astro
  frontmatter fails the build.
*/
const TIME_RE = /^([01]\d|2[0-3]):[0-5]\d$/;
const SLUG_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/; // kebab-case; "516" (kebab-of-digits) is valid
const CANONICAL_KEYS = ['name', 'slug', 'bear_trap_1', 'bear_trap_2', 'peak', 'farm_alliance', 'official'];

function fail(msg: string): never {
  throw new Error(`alliances.json is invalid — ${msg}. Fix site/src/data/alliances.json and rebuild.`);
}
function isTimeOrNull(v: unknown): boolean {
  return v === null || (typeof v === 'string' && TIME_RE.test(v));
}
function isStringOrNull(v: unknown): boolean {
  return v === null || typeof v === 'string';
}
function validateAlliances(data: unknown): Alliance[] {
  if (!Array.isArray(data)) fail('the top-level value is not an array');
  const seen = new Set<string>();
  data.forEach((row: unknown, i: number) => {
    const at = `row ${i}`;
    if (typeof row !== 'object' || row === null || Array.isArray(row)) fail(`${at} is not an object`);
    const r = row as Record<string, unknown>;
    const keys = Object.keys(r);
    if (keys.length !== CANONICAL_KEYS.length || !CANONICAL_KEYS.every((k) => k in r)) {
      fail(`${at} must have exactly the 7 canonical keys [${CANONICAL_KEYS.join(', ')}] (got [${keys.join(', ')}])`);
    }
    if (typeof r.name !== 'string' || r.name.trim() === '') fail(`${at} "name" must be a non-empty string`);
    if (typeof r.slug !== 'string' || r.slug.trim() === '') fail(`${at} "slug" must be a non-empty string`);
    if (!SLUG_RE.test(r.slug)) fail(`${at} "slug" must be kebab-case (got "${r.slug}")`);
    if (seen.has(r.slug)) fail(`duplicate slug "${r.slug}"`);
    seen.add(r.slug);
    if (!isTimeOrNull(r.bear_trap_1)) fail(`${at} "bear_trap_1" must be null or "HH:MM" (got ${JSON.stringify(r.bear_trap_1)})`);
    if (!isTimeOrNull(r.bear_trap_2)) fail(`${at} "bear_trap_2" must be null or "HH:MM" (got ${JSON.stringify(r.bear_trap_2)})`);
    if (!isTimeOrNull(r.peak)) fail(`${at} "peak" must be null or "HH:MM" (got ${JSON.stringify(r.peak)})`);
    if (!isStringOrNull(r.farm_alliance)) fail(`${at} "farm_alliance" must be a string or null`);
    if (!isStringOrNull(r.official)) fail(`${at} "official" must be a string or null`);
  });
  // An empty array is a VALID state (Story 2.3 renders zero gracefully) — never a build error.
  return data as Alliance[];
}

const alliances = validateAlliances(alliancesData);
const allianceCount = alliances.length;

/*
  Curated IANA list for the manual "change" override — a native <select>, no tz
  library (KISS). Spans the offset range including the fractional zones
  (+5:30 / +5:45 / +6:30 / +9:30) so conversion is exercised at the edges.
*/
const TZ_OPTIONS = [
  'Pacific/Honolulu', 'America/Anchorage', 'America/Los_Angeles', 'America/Denver',
  'America/Chicago', 'America/New_York', 'America/Halifax', 'America/Sao_Paulo',
  'Atlantic/Azores', 'UTC', 'Europe/London', 'Europe/Berlin', 'Europe/Athens',
  'Europe/Moscow', 'Asia/Dubai', 'Asia/Karachi', 'Asia/Kolkata', 'Asia/Kathmandu',
  'Asia/Dhaka', 'Asia/Yangon', 'Asia/Bangkok', 'Asia/Shanghai', 'Asia/Tokyo',
  'Australia/Adelaide', 'Australia/Sydney', 'Pacific/Auckland',
];
---

<Layout title="Kingdom 1516 — Alliance Finder">
  <main class="finder">
    {/*
      Skeleton marker — render-blocking, mirrors the no-FOUC theme init in
      Layout.astro. Sets a root flag the instant JS can run so the result cards
      show a brief skeleton during the client-side UTC→local resolve; the module
      <script> clears it right after render(). No JS → flag never set → the rule
      never matches → real (honest UTC) cards show immediately, never a frozen
      shimmer. (AC1; no-JS safety.)
    */}
    <script is:inline>document.documentElement.dataset.finderResolving = '';</script>

    <header class="finder-head">
      <div class="ribbon"><span class="ribbon-band">Alliance Finder</span></div>
      <h1>Find the alliance that fits your evening.</h1>
      <p class="lead" id="finder-lead">Ranked by your local time — best fit first.</p>
    </header>

    <div class="tz-row">
      <span class="tz-pin" aria-hidden="true"><Icon name="map-pin" /></span>
      <p class="tz-text">
        Your timezone: <b id="tz-name">UTC</b>
        <span class="tz-detected" id="tz-detected">default</span>
      </p>
      <button
        type="button"
        class="tz-change"
        id="tz-change"
        aria-expanded="false"
        aria-controls="tz-select-wrap"
      >change</button>
      <label class="tz-select-wrap" id="tz-select-wrap" hidden>
        <span class="label">Pick your timezone</span>
        <select id="tz-select">
          {TZ_OPTIONS.map((tz) => <option value={tz}>{tz}</option>)}
        </select>
      </label>
    </div>

    {/*
      Personal peak-window input (Story 2.5). Sits next to the timezone control —
      windows are read in the visitor's LOCAL time, so they belong with the tz row.
      One empty row is server-rendered (no-JS honesty: inert inputs that do nothing
      with JS off, never a broken/blocking state). The module <script> below wires
      add/remove, validation, persistence, and windows-aware re-ranking. The remove
      <button> ships hidden on this first row; new rows clone it (carrying the inline
      Lucide "x" SVG — one icon mechanism, no emoji).
    */}
    <section class="peak-row" aria-labelledby="peak-q">
      <div class="peak-head">
        <span class="peak-ic" aria-hidden="true"><Icon name="clock" /></span>
        <div class="peak-head-text">
          <p class="peak-q" id="peak-q">When are you usually active?</p>
          <p class="peak-hint">Optional — leave empty to use the standard evening.</p>
        </div>
      </div>
      <div class="peak-windows" id="peak-windows">
        <div class="peak-window" data-peak-window>
          <div class="peak-fields">
            <input type="time" class="peak-input" data-peak-start aria-label="Active window start time" />
            <span class="peak-dash" aria-hidden="true">–</span>
            <input type="time" class="peak-input" data-peak-end aria-label="Active window end time" />
            <button type="button" class="peak-remove" data-peak-remove hidden aria-label="Remove this window"><Icon name="x" /></button>
          </div>
          <p class="peak-error" data-peak-error hidden></p>
        </div>
      </div>
      <button type="button" class="peak-add" id="peak-add">
        <span class="peak-add-ic" aria-hidden="true"><Icon name="plus" /></span>add window
      </button>
    </section>

    <p class="reassure">
      <span class="reassure-ic" aria-hidden="true"><Icon name="check" /></span>These are recommendations.
    </p>

    <section class="results" aria-label="Alliance recommendations">
      {/*
        Zero / empty-dataset state (AC4). An empty alliances.json is a valid build
        state — render plainly and still route to Apply (never dead-end). The
        generic Apply button carries NO data-slug/name (no alliance to pre-fill);
        the contract is Story 2.4, so it keeps the /join placeholder. The result
        <ol> stays in the DOM but renders empty, so the client script's element
        lookups still resolve safely.
      */}
      {allianceCount === 0 ? (
        <div class="zero-state">
          <span class="zero-ic" aria-hidden="true"><Icon name="building-2" /></span>
          <div class="zero-text">
            <p class="zero-head">No alliances are listed yet.</p>
            <p class="zero-sub">You can still apply to transfer — we'll help you find a fitting alliance once the list is in.</p>
          </div>
          <div class="ac-foot">
            <a class="btn-gold" href="/join">Apply to transfer</a>
            <span class="prefill-note">You can pick your alliance later.</span>
          </div>
        </div>
      ) : (
        <div class="section-head">
          <h2>Your best matches</h2>
          <span class="count" id="result-count">
            {allianceCount} {allianceCount === 1 ? 'alliance' : 'alliances'} · times shown in UTC
          </span>
        </div>
      )}

      {/*
        No-good-match banner (AC2) — hidden until the client render() finds no
        Great/Good fit for this timezone, then revealed ABOVE the still-rendered,
        still-appliable Stretch cards. Re-evaluated on every render (tz change).
      */}
      {allianceCount > 0 && (
        <div class="empty-banner" id="empty-banner" hidden>
          <span class="empty-ic" aria-hidden="true"><Icon name="moon" /></span>
          <div class="empty-text">
            <p class="empty-head">No alliance lands squarely in your evening — here are the closest.</p>
            <p class="empty-sub">None of our Major alliances peak during your evening right now. These are the nearest stretch matches, so you still have a place to start.</p>
          </div>
        </div>
      )}

      <ol class="result-list" id="result-list">
        {alliances.map((a) => {
          const bearTimes = [a.bear_trap_1, a.bear_trap_2].filter((t): t is string => t !== null);
          return (
            <li
              class="alliance-card"
              data-slug={a.slug}
              data-name={a.name}
              data-bear1={a.bear_trap_1 ?? ''}
              data-bear2={a.bear_trap_2 ?? ''}
              data-peak={a.peak ?? ''}
            >
              <div class="ac-skeleton" aria-hidden="true">
                <div class="sk-bar sk-title"></div>
                <div class="sk-bar sk-meta"></div>
                <div class="sk-bar sk-block"></div>
                <div class="sk-bar sk-btn"></div>
              </div>

              <div class="ac-top">
                <span class="ac-name">{a.name}</span>
                <span class="badge-major">Major</span>
                <span class="fit-badge fit-stretch" data-fit>
                  <span class="fit-dots" aria-hidden="true">●○○</span>
                  <span class="fit-label">Stretch</span>
                </span>
              </div>

              {a.farm_alliance && (
                <p class="ac-farm">Farm alliance: <b>{a.farm_alliance}</b></p>
              )}

              <div class="times">
                <div class="time-block">
                  <div class="lbl">
                    <span class="lbl-ic" aria-hidden="true"><Icon name="clock" /></span>
                    <span class="lbl-text">Bear Trap · UTC</span>
                  </div>
                  <div class="bear-times" data-bear-times>
                    {bearTimes.length === 0 && <span class="t-none">No Bear Trap time set</span>}
                    {bearTimes.length === 1 && <span class="t">{bearTimes[0]}</span>}
                    {bearTimes.length === 2 && (
                      <Fragment>
                        <span class="t">{bearTimes[0]}</span>
                        <span class="amp">&amp;</span>
                        <span class="t">{bearTimes[1]}</span>
                      </Fragment>
                    )}
                  </div>
                </div>

                {a.peak && (
                  <div class="time-block peak-block">
                    <div class="lbl">
                      <span class="lbl-ic" aria-hidden="true"><Icon name="swords" /></span>
                      <span class="lbl-text">Peak activity · UTC</span>
                    </div>
                    <div class="peak-val" data-peak-val>{a.peak}</div>
                  </div>
                )}
              </div>

              <div class="ac-foot">
                <a class="btn-gold" href={`/join?alliance=${encodeURIComponent(a.slug)}&name=${encodeURIComponent(a.name)}`} data-slug={a.slug} data-name={a.name}>Apply to transfer</a>
                <span class="prefill-note">Pre-fills this alliance — you can change it.</span>
              </div>
            </li>
          );
        })}
      </ol>
    </section>
  </main>
</Layout>

<style>
  /*
    Finder-only component recipes (tz row, alliance card, fit/Major badges, gold
    Apply button, Best-fit ribbon) live here. This is consumer #2 of the gold-button
    recipe (Home is #1) — Rule of Three says copy, don't extract until the 3rd.
    Tokens are role-named; the only literal hex are the DESIGN gold gradient stops
    the mockup spells out, and every light-baked gradient gets a dark variant.
    Fit-badge / Major / tz-change tints use color-mix on a role token, so they flip
    with the theme automatically (no separate dark rule needed).
  */
  .finder {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-9);
  }

  /* ===== Heading + ribbon (recipe mirrors Home) ===== */
  .finder-head {
    position: relative;
    text-align: center;
    padding: var(--space-5) var(--space-4) 0;
  }
  .ribbon {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .ribbon::before,
  .ribbon::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 54px;
    height: 16px;
    background: var(--color-primary);
    transform: translateY(-50%);
    box-shadow: 0 2px 4px rgba(44, 38, 34, .2);
    display: none; /* desktop-only ornament; shown at 768px (see breakpoint) */
  }
  .ribbon::before {
    left: -66px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 12px 50%);
  }
  .ribbon::after {
    right: -66px;
    clip-path: polygon(0 0, 100% 0, calc(100% - 12px) 50%, 100% 100%, 0 100%);
  }
  .ribbon-band {
    display: inline-block;
    background: linear-gradient(#E8A149, #E08A2B);
    color: var(--color-primary-foreground);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(224, 138, 43, .35), inset 0 1px 0 rgba(255, 255, 255, .4);
    text-shadow: 0 1px 1px rgba(44, 38, 34, .3);
  }
  .finder-head h1 {
    font-size: clamp(24px, 6vw, 34px);
    line-height: 1.1;
    max-width: 560px;
    margin: var(--space-4) auto var(--space-2);
    color: var(--color-ink);
  }
  .finder-head .lead {
    color: var(--color-muted);
    font-size: 15px;
    margin: 0;
  }

  /* ===== Timezone row ===== */
  .tz-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin: var(--space-6) 0 var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(#FDF9EF, #F8EFD8);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-card);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .5);
  }
  .tz-pin {
    flex: none;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-button);
    background: linear-gradient(#FBE4C2, #F4CF9C);
    border: 1px solid var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    color: var(--color-primary-hover);
  }
  .tz-text {
    margin: 0;
    font-size: 14.5px;
    color: var(--color-ink);
  }
  .tz-detected {
    color: var(--color-muted);
    font-size: 12px;
    font-weight: 600;
    margin-left: var(--space-2);
  }
  .tz-change {
    margin-left: auto;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    border-radius: 7px;
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
  }
  .tz-change:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .tz-change:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .tz-select-wrap {
    flex-basis: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-top: var(--space-2);
  }
  .tz-select-wrap[hidden] {
    display: none;
  }
  #tz-select {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    padding: var(--space-2) var(--space-3);
  }

  /* ===== Personal peak windows (Story 2.5) — backgrounds use role tokens only,
     so both themes flip automatically: no baked light gradient → no dark variant
     needed (the 1.3/1.4 wash-out guard is honored by avoiding the problem). ===== */
  .peak-row {
    margin: 0 0 var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .peak-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .peak-ic {
    flex: none;
    margin-top: 2px;
    color: var(--color-primary-hover);
    display: inline-flex;
  }
  .peak-q {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }
  .peak-hint {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }
  .peak-windows {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .peak-window {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .peak-fields {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .peak-input {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    padding: var(--space-2) var(--space-3);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }
  .peak-input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .peak-dash {
    color: var(--color-muted);
    font-size: 14px;
  }
  .peak-remove {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    cursor: pointer;
    font-size: 15px;
  }
  .peak-remove[hidden] {
    display: none;
  }
  .peak-remove:hover {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-muted) 12%, transparent);
  }
  .peak-remove:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .peak-error {
    font-size: 12px;
    color: var(--color-primary-hover);
    margin: 0;
  }
  .peak-error[hidden] {
    display: none;
  }
  .peak-add {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    border-radius: 7px;
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
  }
  .peak-add-ic {
    display: inline-flex;
    font-size: 15px;
  }
  .peak-add:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .peak-add:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* ===== Reassurance (AC5 — above results; repeated near Apply via prefill note) ===== */
  .reassure {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-2) 0 var(--space-5);
    font-size: 13px;
    color: var(--color-muted);
  }
  .reassure-ic {
    color: var(--color-accent);
    display: inline-flex;
  }

  /* ===== Section head ===== */
  .section-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin: 0 0 var(--space-4);
  }
  .section-head h2 {
    font-size: 18px;
    margin: 0;
    color: var(--color-ink);
  }
  .section-head .count {
    font-size: 12px;
    color: var(--color-muted);
    font-weight: 600;
  }

  /* ===== Result list / alliance cards ===== */
  .result-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .alliance-card {
    position: relative;
    background: linear-gradient(180deg, #FDF9EF, #F8EFD8);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card);
    padding: var(--space-5);
    box-shadow:
      0 8px 20px rgba(224, 138, 43, .18),
      inset 0 0 0 1px rgba(255, 255, 255, .5),
      inset 0 0 22px rgba(224, 138, 43, .06);
  }
  /* Best-fit ribbon — rank-1 only (set client-side after ranking) */
  .alliance-card.rank-1::after {
    content: 'Best fit';
    position: absolute;
    top: -11px;
    left: var(--space-5);
    background: linear-gradient(#E8A149, #E08A2B);
    color: var(--color-primary-foreground);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 5px;
    box-shadow: 0 3px 7px rgba(224, 138, 43, .35);
  }

  .ac-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-1);
  }
  .ac-name {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--color-ink);
  }
  .badge-major {
