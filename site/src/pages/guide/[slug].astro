---
/*
  /guide/<slug> — the public guide reader (Story 6.4, ⭐ Q1 Option B). One
  static page per `guides` row; the slug is the immutable public address
  (AR-18 — preview URL == public URL, category changes can never break it,
  hence the category-independent /guide/ family).

  The body seam is the story's crux: `guide.body` arrives SANITIZED from the
  data layer (the §18.2 MUST — scripts/handlers/foreign iframes are already
  dead), then localizeGuideImages() downloads + optimizes every referenced
  Directus original and rewrites it to a local hashed asset — the rendered
  page carries ZERO Directus URLs (AD-2) and renders with Directus offline
  (NFR-2). set:html is safe HERE and only here, on that pipeline's output.

  Markup stays plain and semantic (real headings — the body's h1 is demoted to
  h2 by the sanitizer, the page h1 is the title —, real tables, real links):
  that is the whole i18n mechanism (NFR-6/AD-14, browser auto-translate).
*/
import Layout from '../../layouts/Layout.astro';
import { guides, type Guide } from '../../data/guides';
import { localizeGuideImages } from '../../lib/guide-images';
import { stripToExcerpt } from '../../lib/sanitize-guide';

export function getStaticPaths() {
  return guides.map((g) => ({ params: { slug: g.slug }, props: { guide: g } }));
}

interface Props {
  guide: Guide;
}
const { guide } = Astro.props;
const body = await localizeGuideImages(guide.body);
const description = stripToExcerpt(guide.body, 160);
const day = guide.updated ? guide.updated.slice(0, 10) : null;
---

<Layout title={`${guide.title} — Kingdom 1516 Guides`} description={description || undefined}>
  <main class="guide-page">
    <p class="crumb">
      <a href="/guides/">Guides</a>
      {guide.category && <> · <a href={`/guides/${guide.category.slug}/`}>{guide.category.name}</a></>}
    </p>
    <article>
      <header class="guide-head">
        {
          guide.category && (
            <a class="badge-category" href={`/guides/${guide.category.slug}/`}>
              {guide.category.name}
            </a>
          )
        }
        <h1>{guide.title}</h1>
        <p class="guide-meta muted">
          {day && <>Updated <time datetime={guide.updated}>{day}</time></>}
          {day && guide.creator_credit && ' · '}
          {guide.creator_credit && <>credit: {guide.creator_credit}</>}
        </p>
      </header>
      <div class="guide-body" set:html={body} />
    </article>
  </main>
</Layout>

<style>
  /* Reading column — long-line readability over grid width. */
  .guide-page {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-9);
  }
  .crumb {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }
  .crumb a {
    color: inherit;
  }

  .badge-category {
    display: inline-block;
    background: rgba(42, 167, 176, 0.14);
    color: #1c7c83;
    border: 1px solid rgba(42, 167, 176, 0.4);
    border-radius: var(--radius-pill);
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: var(--space-3);
  }
  :global(:root[data-theme='dark']) .badge-category {
    color: #6fd3da;
    background: rgba(42, 167, 176, 0.18);
  }
  .guide-head h1 {
    margin: var(--space-2) 0 0;
  }
  .guide-meta {
    font-size: 13px;
    margin: var(--space-2) 0 0;
  }

  /*
    WYSIWYG body typography: information text is Inter/ink at high contrast
    (NFR-5); headings inherit the display font from global.css. All selectors
    are :global() because the content comes from set:html (no Astro scoping).
  */
  .guide-body {
    margin-top: var(--space-6);
    line-height: 1.65;
  }
  .guide-body :global(p) {
    margin: var(--space-4) 0;
  }
  .guide-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
  .guide-body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
    border-radius: var(--radius-sm);
  }
  /* Wide tables scroll inside their own box, never the page (NFR-13). */
  .guide-body :global(table) {
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    margin: var(--space-5) 0;
  }
  .guide-body :global(th),
  .guide-body :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
    font-family: var(--font-body);
  }
  .guide-body :global(th) {
    background: var(--color-highlight);
  }
  .guide-body :global(a) {
    color: var(--color-primary-hover);
  }
  .guide-body :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: var(--space-4) 0;
    padding-left: var(--space-4);
    color: var(--color-muted);
  }
</style>
