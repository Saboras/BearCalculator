---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

// Whole-card-tappable entry points (AC2). Icons are inline Lucide SVGs
// (currentColor, no image assets). Forward links point at their intended
// final kebab-case routes; they light up as later stories land.
const entryCards = [
  {
    icon: 'wrench',
    title: 'Tools',
    copy: 'Our Bear Trap squad calculator + curated external calculators.',
    cta: 'Open tools →',
    href: '/tools',
  },
  {
    icon: 'compass',
    title: 'Alliance Finder',
    copy: 'Match by your timezone.',
    cta: 'Find your alliance →',
    href: '/finder',
  },
  {
    icon: 'book-open',
    title: 'Guides',
    copy: 'How events work — Events · Troops & Heroes · Alliance & Transfer.',
    cta: 'Browse guides →',
    href: '/guides',
  },
];
---

<Layout title="Kingdom 1516 — Guides, Calculators & Alliance Finder">
  <main class="home">
    <section class="hero">
      <div class="ribbon"><span class="ribbon-band">Kingdom 1516</span></div>
      <h1 class="hero-title">Your kingdom, in one place.</h1>
      <p class="hero-sub">Guides, calculators, and the alliance that fits your timezone.</p>
      <a class="button-primary" href="/finder">Join Kingdom 1516 →</a>
      <p class="hero-reassure">New here? Find the alliance that fits your timezone and apply to transfer.</p>
    </section>

    <section class="entry">
      <h2 class="entry-heading">Get started</h2>
      <div class="cards">
        {entryCards.map((c) => (
          <a class="card" href={c.href}>
            <span class="card-icon" aria-hidden="true"><Icon name={c.icon} /></span>
            <h3 class="card-title">{c.title}</h3>
            <p class="card-copy">{c.copy}</p>
            <span class="card-cta">{c.cta}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  /*
    Home-only component recipes (button-primary, card, ribbon-banner) live here:
    Home is their first and only consumer today (KISS/YAGNI — extract to a shared
    component on the third consumer per Rule of Three). Tokens are role-named so
    the theme swap works; the only literal hex are the DESIGN gradient stops the
    mockup spells out verbatim, and every one gets a [data-theme="dark"] variant.
  */

  .home {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-9);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    overflow: hidden; /* clip the ribbon flag-tails so they never cause h-scroll */
    text-align: center;
    padding: var(--space-7) var(--space-4) var(--space-6);
  }

  /* Ribbon-banner — landing-level only (AC3). The wrapper carries the gold
     flag/pennant tails; the band carries the tracked-uppercase Lilita One text
     (.ribbon already gets --font-display from global.css). */
  .ribbon {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-2);
  }
  .ribbon::before,
  .ribbon::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 64px;
    height: 18px;
    background: var(--color-primary);
    transform: translateY(-50%);
    box-shadow: 0 2px 4px rgba(44, 38, 34, .2);
    /* desktop-only ornament — the hero is too narrow on phones to show the
       ±78px tails, so .hero overflow:hidden would just amputate them. Re-enabled
       at the 768px breakpoint where there is room. */
    display: none;
  }
  .ribbon::before {
    left: -78px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 14px 50%);
  }
  .ribbon::after {
    right: -78px;
    clip-path: polygon(0 0, 100% 0, calc(100% - 14px) 50%, 100% 100%, 0 100%);
  }
  .ribbon-band {
    display: inline-block;
    background: linear-gradient(#E8A149, #E08A2B);
    color: var(--color-primary-foreground);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-sm);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(224, 138, 43, .35), inset 0 1px 0 rgba(255, 255, 255, .4);
    text-shadow: 0 1px 1px rgba(44, 38, 34, .3);
  }

  .hero-title {
    /* fluid: comfortable on a phone, full 46px display on desktop — no breakpoint */
    font-size: clamp(30px, 7vw, 46px);
    line-height: 1.1;
    max-width: 620px;
    margin: var(--space-5) auto var(--space-3);
    color: var(--color-ink);
  }
  .hero-sub {
    color: var(--color-muted);
    font-size: 17px;
    line-height: 1.5;
    max-width: 520px;
    margin: 0 auto var(--space-6);
  }
  .hero-reassure {
    color: var(--color-muted);
    font-size: 13px;
    line-height: 1.45;
    max-width: 420px;
    margin: var(--space-3) auto 0;
  }

  /* ===== button-primary — glossy gold, the single most prominent element (AC1) ===== */
  .button-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    max-width: 360px; /* full-width tap target on mobile, capped so it stays a button */
    background: linear-gradient(#EDA44E, #E08A2B);
    color: var(--color-primary-foreground);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 17px;
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-primary-hover);
    border-radius: var(--radius-button);
    box-shadow:
      0 6px 14px rgba(224, 138, 43, .35),
      inset 0 1px 0 rgba(255, 255, 255, .45),
      inset 0 -2px 4px rgba(201, 120, 31, .3);
    text-shadow: 0 1px 1px rgba(44, 38, 34, .25);
  }
  .button-primary:hover {
    background: linear-gradient(#E08A2B, #C9781F);
    text-decoration: none;
  }
  .button-primary:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* ===== Entry cards ===== */
  .entry-heading {
    text-align: center;
    font-size: 22px;
    color: var(--color-ink);
    margin: var(--space-8) 0 var(--space-5);
  }
  .cards {
    display: grid;
    grid-template-columns: 1fr; /* mobile: single-column stack */
    gap: var(--space-5);
  }

  /* card — gold-framed parchment; the WHOLE card is the link (AC2 / UX-DR-20) */
  .card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: linear-gradient(180deg, #FDF9EF, #F8EFD8);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card);
    padding: var(--space-6) var(--space-5) var(--space-5);
    color: var(--color-ink); /* override global a{color:accent} so card body is ink */
    text-decoration: none;
    box-shadow:
      0 8px 20px rgba(224, 138, 43, .18),
      inset 0 0 0 1px rgba(255, 255, 255, .5),
      inset 0 0 22px rgba(224, 138, 43, .07);
    transition: transform .12s ease, box-shadow .12s ease;
  }
  .card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow:
      0 12px 26px rgba(224, 138, 43, .26),
      inset 0 0 0 1px rgba(255, 255, 255, .5),
      inset 0 0 22px rgba(224, 138, 43, .07);
  }
  .card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
  .card-icon {
    width: 42px;
    height: 42px;
    border-radius: var(--radius-card);
    background: linear-gradient(#FBE4C2, #F4CF9C);
    border: 1px solid var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    line-height: 1;
    margin-bottom: var(--space-3);
  }
  .card-title {
    font-size: 18px;
    color: var(--color-ink);
    margin: 0 0 var(--space-2);
  }
  .card-copy {
    color: var(--color-muted);
    font-size: 13.5px;
    line-height: 1.45;
    margin: 0 0 var(--space-4);
  }
  .card-cta {
    margin-top: auto; /* pin CTA to the bottom so cards align across the row */
    color: var(--color-accent);
    font-weight: 600;
    font-size: 13.5px;
  }
  .card:hover .card-cta {
    color: var(--color-primary-hover);
  }
  /* The global reduced-motion rule only zeroes transition-duration; the lift
     would still jump. Drop the displacement entirely for these users. */
  @media (prefers-reduced-motion: reduce) {
    .card:hover {
      transform: none;
    }
  }

  /* ===== Desktop enhancement (single breakpoint, mirrors the shell) ===== */
  @media (min-width: 768px) {
    .hero {
      padding: var(--space-8) var(--space-6) var(--space-7);
    }
    .ribbon::before,
    .ribbon::after {
      display: block; /* room to show the flag-tails un-clipped */
    }
    .button-primary {
      width: auto;
    }
    .cards {
      grid-template-columns: repeat(3, 1fr); /* desktop: 3-up entry-card grid */
    }
  }

  /* ===== Dark "Royal Court" — every light-baked gradient/emboss needs a dark variant.
     (The Story 1.3 lesson: light-only chrome gradients washed out in dark mode.) ===== */
  :global(:root[data-theme="dark"]) .ribbon-band {
    background: linear-gradient(#F2A93B, #E0962A);
    text-shadow: none; /* dark-ink text on bright gold needs no dark emboss */
  }
  :global(:root[data-theme="dark"]) .button-primary {
    background: linear-gradient(#F2A93B, #E0962A);
    box-shadow:
      0 6px 16px rgba(242, 169, 59, .3),
      inset 0 1px 0 rgba(255, 255, 255, .25),
      inset 0 -2px 4px rgba(0, 0, 0, .25);
    text-shadow: none;
  }
  :global(:root[data-theme="dark"]) .button-primary:hover {
    background: linear-gradient(#E0962A, #C9781F);
  }
  :global(:root[data-theme="dark"]) .card {
    background: linear-gradient(var(--color-surface), var(--color-bg));
    box-shadow:
      0 8px 20px rgba(0, 0, 0, .35),
      inset 0 0 0 1px rgba(255, 255, 255, .04),
      inset 0 0 22px rgba(242, 169, 59, .05);
  }
  :global(:root[data-theme="dark"]) .card:hover {
    box-shadow:
      0 12px 26px rgba(0, 0, 0, .45),
      inset 0 0 0 1px rgba(255, 255, 255, .04),
      inset 0 0 22px rgba(242, 169, 59, .05);
  }
  :global(:root[data-theme="dark"]) .card-icon {
    background: linear-gradient(rgba(242, 169, 59, .18), rgba(242, 169, 59, .07));
  }
</style>
