---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

/*
  /admin — the custom admin shell (Story 3.5), the Structural-Seed "custom Candidates
  admin shell" path. A no-JS-safe frame that a bundled module fills client-side with the
  leader session: a role chip + a tab strip whose tabs are PRESENT ONLY for areas the
  leader can access (absent, not disabled — UX-DR-17). Only Candidates is a custom surface
  (a placeholder here; the pipeline is Epic 5); Guides/Alliances/Accounts hand off to the
  Directus Data Studio (AR-5/NFR-18).

  Static-site model (AD-1/AD-2): output:'static', no SSR/API route. All data is fetched in
  the browser with the httpOnly session cookie — the static HTML bakes ZERO admin data.
  The gate is UX-only; Directus server-enforces 401/403 regardless (AD-4).
*/
---

<Layout title="Kingdom 1516 — Admin">
  <main class="admin">
    {/* No-JS-safe default: the whole shell needs JS + a leader session. Nothing admin here. */}
    <noscript>
      <div class="admin-note">
        <h1>Admin</h1>
        <p>The admin area needs JavaScript enabled and a leader sign-in.</p>
        <p><a href="/leader">Go to the leader login →</a></p>
      </div>
    </noscript>

    {/* Loading — the default visible state; the module swaps to shell / empty / error. */}
    <div class="admin-state" id="admin-loading">
      <p class="muted">Loading the admin shell…</p>
    </div>

    {/* Backend-unreachable (not a 401 — those redirect to /leader). */}
    <div class="admin-state" id="admin-error" hidden>
      <p class="admin-msg" role="alert">Couldn’t reach the admin backend. Please try again.</p>
      <button type="button" class="btn-gold btn-narrow" id="admin-retry">Retry</button>
    </div>

    {/* Signed in, but no area granted yet (deny-by-default). */}
    <div class="admin-state" id="admin-empty" hidden>
      <p class="admin-msg">No admin areas are assigned to your account yet. Ask the Owner to grant you access.</p>
      <button type="button" class="btn-plain" id="admin-empty-logout">Log out</button>
    </div>

    {/* The shell — revealed only after a confirmed session with ≥1 accessible area. */}
    <div class="shell" id="admin-shell" hidden>
      <header class="shell-head">
        <div class="shell-brand">Kingdom <span class="shell-num">1516</span> <small>Admin</small></div>
        <div class="role-chips" id="role-chips" aria-label="Your roles"></div>
        <button type="button" class="shell-logout" id="admin-logout">
          <Icon name="shield" /> Log out
        </button>
      </header>

      <nav class="tabs" id="admin-tabs" aria-label="Admin areas" role="tablist"></nav>

      <section class="panels" id="admin-panels"></section>
    </div>
  </main>
</Layout>

<style is:global>
  .admin {
    /* DESIGN Layout & Spacing: the candidate table is a wide data surface —
       desktop content max ~1100–1180px (960 clipped the table on desktops). */
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4) var(--space-9);
  }

  /* ===== States (loading / error / empty) ===== */
  .admin-state {
    max-width: 520px;
    margin: var(--space-7) auto;
    text-align: center;
  }
  .admin-state[hidden] {
    display: none;
  }
  .admin-note {
    max-width: 520px;
    margin: var(--space-7) auto;
    text-align: center;
  }
  .admin-msg {
    color: var(--color-ink);
    font-size: 15px;
    margin: 0 0 var(--space-5);
  }
  #admin-error .admin-msg {
    color: var(--color-danger);
  }

  /* ===== The shell ===== */
  .shell[hidden] {
    display: none;
  }

  /* Shell header — wordmark + role chips + logout. Mirrors the topbar chrome recipe
     (light parchment literal; dark variant below is the 1.3/1.4 wash-out guard). */
  .shell-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: linear-gradient(#FBF6EA, #F1E6CC);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    box-shadow: 0 4px 14px rgba(224, 138, 43, .14);
  }
  .shell-brand {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--color-primary);
    letter-spacing: .3px;
  }
  .shell-num {
    color: var(--color-ink);
  }
  .shell-brand small {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-muted);
    margin-left: var(--space-1);
  }

  /* Role chip(s) — gold pill (the mockup recipe), theme-aware via tokens. */
  .role-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-left: auto;
  }
  .role-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(224, 138, 43, .14);
    border: 1px solid var(--color-primary);
    color: var(--color-primary-hover);
    font-weight: 700;
    font-size: 12px;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .role-chip .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .shell-logout {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    padding: 6px var(--space-3);
    border-radius: var(--radius-button);
    cursor: pointer;
  }
  .shell-logout:hover {
    border-color: var(--color-primary);
  }
  .shell-logout:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .shell-logout .icon {
    width: 15px;
    height: 15px;
    color: var(--color-accent);
  }

  /* Tab strip — gold active-underline, absent (not disabled) tabs are simply not built. */
  .tabs {
    display: flex;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4) 0;
    border-left: 2px solid var(--color-primary);
    border-right: 2px solid var(--color-primary);
    background: linear-gradient(#FBF6EA, #FBF6EA);
    overflow-x: auto;
  }
  .tab {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: transparent;
    border: 0;
    border-bottom: 3px solid transparent;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-button) var(--radius-button) 0 0;
    cursor: pointer;
    white-space: nowrap;
  }
  .tab:hover {
    color: var(--color-primary-hover);
  }
  .tab[aria-selected='true'] {
    color: var(--color-primary-hover);
    border-bottom-color: var(--color-primary);
    background: rgba(224, 138, 43, .06);
  }
  .tab:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }
  .tab .icon {
    width: 16px;
    height: 16px;
  }

  /* Panels — gold-framed parchment card (the UX-DR-8 recipe from leader.astro). */
  .panels {
    background: linear-gradient(180deg, #FDF9EF, #F8EFD8);
    border: 2px solid var(--color-primary);
    border-top: 0;
    border-radius: 0 0 var(--radius-card) var(--radius-card);
    padding: var(--space-6) var(--space-5);
    box-shadow:
      0 8px 20px rgba(224, 138, 43, .18),
      inset 0 0 0 1px rgba(255, 255, 255, .5),
      inset 0 0 22px rgba(224, 138, 43, .06);
    min-height: 220px;
  }
  .panel[hidden] {
    display: none;
  }
  .panel h2 {
    font-size: 22px;
    color: var(--color-ink);
    margin: 0 0 var(--space-3);
  }
  .panel p {
    color: var(--color-muted);
    font-size: 15px;
    max-width: 52ch;
  }

  .btn-plain {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-button);
    cursor: pointer;
  }
  .btn-plain:hover {
    border-color: var(--color-primary);
  }
  .btn-plain:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .btn-narrow {
    width: auto;
  }
  .panel .btn-gold {
    width: auto;
    margin-top: var(--space-4);
  }
  .panel .btn-gold .icon {
    width: 16px;
    height: 16px;
  }

  /* ===== Candidates table (Story 5.4) — calm data table (UX-DR-11) ===== */
  .cand-intro {
    color: var(--color-muted);
    font-size: 13.5px;
    margin: 0 0 var(--space-4);
    max-width: 64ch;
  }
  .cand-state {
    margin: var(--space-5) 0;
  }
  .cand-state[hidden] {
    display: none;
  }
  .cand-state .muted {
    color: var(--color-muted);
    font-size: 14px;
  }

  .cand-table-wrap[hidden] {
    display: none;
  }
  /* Story 5.7: the horizontal scroll moved from .cand-table-wrap to this inner box so the cap-strip
     above the table stays fixed while a wide table scrolls under it (the strip is a sibling here). */
  .cand-table-scroll {
    overflow-x: auto; /* wide table scrolls in its own box, never the page body (AC4) */
    -webkit-overflow-scrolling: touch;
  }

  /* ===== Capacity counters strip (Story 5.7) — the gold-framed "room" above the calm table ===== */
  /* Planning aids only, NEVER a gate. The strip gets the frame (a "room"); the table interior stays
     calm (DESIGN Elevation — frame the room, not the chairs). Danger red is RESERVED — never here. */
  .cap-strip {
    background: linear-gradient(#FBF6EA, #F1E6CC); /* warm parchment; dark override below */
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-card);
    box-shadow: 0 6px 18px rgba(224, 138, 43, .14);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
  }
  .cap-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .6px;
    color: var(--color-accent); /* teal (light) / royal-blue (dark) — theme-aware, never raw #2AA7B0 */
    margin-bottom: var(--space-3);
  }
  .cap-counters {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .cap-counter {
    background: #FFFFFF; /* calm white card on the parchment room; dark override below */
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    padding: var(--space-3) var(--space-4);
  }
  .cap-cl {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .4px;
    color: var(--color-muted);
  }
  .cap-cv {
    font-size: 24px;
    font-weight: 700;
    margin-top: 5px;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums; /* every count is tabular (DESIGN Typography) */
  }
  .cap-cv small {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-muted); /* the "/ cap" denominator + " queued" note */
  }
  .cap-counter--editable .cap-cv {
    color: var(--color-primary); /* gold: the live-editable special target (AC-2, never a literal 3) */
  }
  .cap-strip-note {
    font-size: 12px;
    color: var(--color-muted);
    margin: var(--space-3) 0 0;
  }
  /* ===== Guides publish list (Story 6.3) — reuses the calm cand-table styling ===== */
  .guide-publish-cell {
    white-space: nowrap; /* the Publish button + its inline error stay on the action column */
  }
  .guide-slug {
    overflow-wrap: anywhere; /* long kebab slugs wrap inside the cell, never widen the page */
  }
  .guides-studio-note {
    color: var(--color-muted);
    font-size: 12.5px;
    margin: var(--space-4) 0 0;
  }

  /* Calm note when the active window is scoped-empty (rows exist but none in-window) — review P2. */
  .cand-empty-note {
    font-size: 14px;
    color: var(--color-muted);
    margin: var(--space-5) 0 0;
  }

  /* Carry-over badge (Story 5.7) — success family (DESIGN: carry-over confirmation = success green),
     NOT danger, NOT gold. Mirrors the badge-status--accepted success tint for readable text. */
  .badge-carryover {
    display: inline-block;
    margin-left: var(--space-2);
    padding: 1px 8px;
    font-size: 11px;
    font-weight: 700;
    border-radius: var(--radius-sm);
    color: #2f8f52; /* darker green than the #46D17A token for readable text on the light tint */
    background: rgba(70, 209, 122, .16);
    white-space: nowrap;
    vertical-align: middle;
  }

  .cand-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 13.5px;
  }
  /* Uppercase tracked header + 1.5px bottom rule; no per-row frame, no zebra (UX-DR-11). */
  .cand-table thead th {
    text-align: left;
    text-transform: uppercase;
    letter-spacing: .6px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-muted);
    padding: 0 var(--space-3) var(--space-2);
    border-bottom: 1.5px solid var(--color-primary);
    white-space: nowrap;
  }
  .cand-table th.num,
  .cand-table td.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .cand-table tbody td {
    padding: var(--space-3);
    border-bottom: 1px solid var(--color-border); /* hairline separators only */
    color: var(--color-ink);
    vertical-align: top;
  }
  .cand-row td:first-child {
    border-left: 3px solid transparent; /* left-rail accent slot */
  }
  .cand-row--group td:first-child {
    border-left-color: var(--color-primary); /* gold: linked transfer group */
  }
  .cand-row--divergent td:first-child {
    border-left-color: var(--color-danger); /* danger: group has mixed suggestions */
  }

  .cand-name {
    font-weight: 600;
    white-space: nowrap;
  }
  .cand-expand {
    background: transparent;
    border: 0;
    color: var(--color-muted);
    cursor: pointer;
    font-size: 12px;
    padding: 0 4px 0 0;
    line-height: 1;
    display: inline-block;
    transition: transform .15s ease;
  }
  .cand-expand--open {
    transform: rotate(90deg);
  }
  .cand-expand:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Status chip — Applied muted / Accepted+Transferred success / Rejected danger. */
  .badge-status {
    display: inline-block;
    font-size: 11.5px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .badge-status--applied {
    color: var(--color-muted);
    background: rgba(138, 126, 107, .16);
  }
  .badge-status--accepted {
    color: #2f8f52; /* darker green than the #46D17A token for readable text on a light tint */
    background: rgba(70, 209, 122, .16);
  }
  /* Transferred = done & moved on — accent family (teal light / royal-blue dark), so it
     reads apart from the green "Accepted" at a glance. Text darker than the accent token
     for contrast on the light tint (badge-category precedent). */
  .badge-status--transferred {
    color: #1c7c83;
    background: rgba(42, 167, 176, .14);
  }
  .badge-status--rejected {
    color: var(--color-danger);
    background: rgba(216, 53, 42, .14);
  }
  /* Story 6.3: the third guide publish state — published, but the draft carries newer,
     unpublished edits. Amber attention tint (Draft reuses --applied, Published --transferred). */
  .badge-status--draft-newer {
    color: #9a621b; /* darker amber than the gold token for readable text on a light tint */
    background: rgba(224, 138, 43, .16);
  }

  /* Special-invite chip — compact inline variant of DESIGN badge-special (reserved danger). */
  .badge-special-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: var(--space-2);
    padding: 1px 7px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-danger);
    background: rgba(216, 53, 42, .14);
    border: 1px solid rgba(216, 53, 42, .4);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    vertical-align: middle;
  }
  .badge-special-chip .icon {
    width: 12px;
    height: 12px;
  }

  /* Expandable per-row detail (FR-6 "all their fields"). */
  .cand-detail[hidden] {
    display: none;
  }
  .cand-detail > td {
    background: rgba(224, 138, 43, .04);
    padding: var(--space-3) var(--space-4) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .cand-detail-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-2) var(--space-5);
    margin: 0;
  }
  .cand-detail-list dt {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .5px;
    color: var(--color-muted);
    margin-bottom: 1px;
  }
  .cand-detail-list dd {
    margin: 0 0 var(--space-2);
    font-size: 13px;
    color: var(--color-ink);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  @media (prefers-reduced-motion: reduce) {
    .cand-expand {
      transition: none;
    }
  }

  /* ===== Curator status-lifecycle controls (Story 5.5) — inside the per-row detail ===== */
  .cand-actions {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px dashed var(--color-border);
  }
  .cand-actions-head {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .5px;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }
  .cand-action-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .cand-action-row:last-of-type {
    margin-bottom: 0;
  }
  .cand-action-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--color-muted);
    margin-right: var(--space-1);
  }
  .cand-btn {
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: var(--radius-button);
    border: 1px solid transparent;
    cursor: pointer;
    white-space: nowrap;
  }
  .cand-btn:disabled {
    opacity: .55;
    cursor: default;
  }
  .cand-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  /* Gold primary = Accept / Mark Transferred / the chosen path (DESIGN "advance status"). */
  .cand-btn--gold,
  .cand-btn--path-active {
    background: linear-gradient(#EDA44E, #E08A2B);
    border-color: var(--color-primary-hover);
    color: var(--color-primary-foreground);
    text-shadow: 0 1px 1px rgba(44, 38, 34, .25);
  }
  .cand-btn--gold:hover:not(:disabled),
  .cand-btn--path-active:hover:not(:disabled) {
    background: linear-gradient(#E08A2B, #C9781F);
  }
  /* Quiet outline = the not-yet-chosen planned-path options. */
  .cand-btn--path {
    background: var(--color-surface);
    border-color: var(--color-border);
    color: var(--color-ink);
  }
  .cand-btn--path:hover:not(:disabled) {
    border-color: var(--color-primary);
    color: var(--color-primary-hover);
  }
  /* Danger outline = Reject (reserved semantic colour, UX-DR-21). */
  .cand-btn--danger {
    background: transparent;
    border-color: rgba(216, 53, 42, .5);
    color: var(--color-danger);
  }
  .cand-btn--danger:hover:not(:disabled) {
    background: rgba(216, 53, 42, .1);
  }
  .cand-actions-note {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
  }
  .cand-action-msg {
    margin: var(--space-1) 0 0;
    font-size: 12.5px;
    color: var(--color-danger);
  }
  .cand-action-msg[hidden] {
    display: none;
  }

  /* ===== Grouping + suggested-alliance controls (Story 5.6) ===== */
  /* Read-only group summary + the edge-computed divergent flag (both visible to all leaders). */
  .cand-group-summary {
    margin: 0 0 var(--space-2);
    font-size: 12.5px;
    color: var(--color-muted);
  }
  .cand-flag--divergent {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 var(--space-3);
    padding: 6px 10px;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--color-danger);
    background: rgba(216, 53, 42, .08);
    border: 1px solid rgba(216, 53, 42, .4);
    border-radius: var(--radius-sm);
  }
  .cand-flag--divergent .cand-flag-ic {
    display: inline-flex;
    flex: 0 0 auto;
  }
  .cand-flag--divergent .icon {
    width: 15px;
    height: 15px;
  }
  /* Compact danger marker in the Suggested cell — mirrors the special-invite chip idiom. */
  .cand-flag-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: var(--space-2);
    padding: 1px 7px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-danger);
    background: rgba(216, 53, 42, .14);
    border: 1px solid rgba(216, 53, 42, .4);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    vertical-align: middle;
  }
  .cand-flag-chip .icon {
    width: 12px;
    height: 12px;
  }
  /* Suggested-alliance picker + the link-group checklist. */
  .cand-select {
    font-family: var(--font-body);
    font-size: 12.5px;
    padding: 4px 8px;
    border-radius: var(--radius-button);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-ink);
    max-width: 220px;
  }
  .cand-select:disabled {
    opacity: .55;
    cursor: default;
  }
  .cand-select:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .cand-linkpanel {
    margin: var(--space-2) 0 0;
    padding: var(--space-3);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    background: rgba(224, 138, 43, .04);
  }
  .cand-linkpanel[hidden] {
    display: none;
  }
  .cand-linklist {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 4px var(--space-4);
    margin: 0 0 var(--space-3);
    max-height: 240px;
    overflow-y: auto;
  }
  .cand-linkopt {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--color-ink);
    cursor: pointer;
  }
  .cand-linkopt .muted {
    color: var(--color-muted);
    font-size: 11px;
  }
  .cand-linkopt input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ===== Manual delete + window cleanup (Story 5.8) ===== */
  /* Curator toolbar above the table: batch cleanup (danger) + the reachability toggle. It sits
     OUTSIDE the gold cap-strip because danger red is reserved-out there (DESIGN Do's-and-Don'ts). */
  .cand-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .cand-cleanup {
    min-width: 0;
  }
  .cand-toolbar-note {
    font-size: 12.5px;
    color: var(--color-muted);
  }
  .cand-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--color-ink);
    cursor: pointer;
    white-space: nowrap;
  }
  .cand-toggle input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  /* Separate the destructive per-row Delete from the status/group actions above it. */
  .cand-action-row--delete {
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px dashed var(--color-border);
  }
  /* The between-windows cleanup confirmation (mockup .cleared) — a calm dashed card with a
     success-green carry-over pill (carry-over confirmation = success, never danger). */
  .cand-cleared {
    position: relative;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
    text-align: center;
  }
  .cand-cleared-dismiss {
    position: absolute;
    top: 4px;
    right: 10px;
    background: transparent;
    border: 0;
    font-size: 18px;
    line-height: 1;
    color: var(--color-muted);
    cursor: pointer;
  }
  .cand-cleared-dismiss:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .cand-cleared-head {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--color-primary); /* gold headline */
    margin-bottom: var(--space-2);
  }
  .cand-cleared-body {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0 auto var(--space-3);
    max-width: 46ch;
  }
  .cand-cleared-counts {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums; /* tabular counts (DESIGN Typography) */
    margin: 0 0 var(--space-3);
  }
  .cand-cleared-pill {
    display: inline-block;
    padding: 3px 10px;
    font-size: 11.5px;
    font-weight: 700;
    border-radius: var(--radius-pill);
    color: #2f8f52; /* darker green than the #46D17A token for readable text on the light tint */
    background: rgba(70, 209, 122, .16);
  }

  /* ===== Dark "Royal Court" — the light-baked parchment/gold literals need dark variants. ===== */
  :root[data-theme='dark'] .shell-head,
  :root[data-theme='dark'] .tabs {
    background: linear-gradient(var(--color-surface), var(--color-bg));
  }
  :root[data-theme='dark'] .role-chip {
    background: rgba(242, 169, 59, .14);
  }
  :root[data-theme='dark'] .panels {
    background: linear-gradient(var(--color-surface), var(--color-bg));
    box-shadow:
      0 8px 20px rgba(0, 0, 0, .35),
      inset 0 0 0 1px rgba(255, 255, 255, .04),
      inset 0 0 22px rgba(242, 169, 59, .05);
  }
  /* Candidate chips — the light-baked tints wash out on the dark card. */
  :root[data-theme='dark'] .badge-status--applied {
    background: rgba(154, 163, 178, .18);
  }
  :root[data-theme='dark'] .badge-status--accepted {
    color: var(--color-success);
    background: rgba(95, 227, 148, .14);
  }
  :root[data-theme='dark'] .badge-status--transferred {
    color: #a7b8f5; /* lightened royal blue — the dark-mode accent family */
    background: rgba(110, 140, 240, .18);
  }
  :root[data-theme='dark'] .badge-status--rejected,
  :root[data-theme='dark'] .badge-special-chip {
    color: var(--color-danger);
    background: rgba(216, 53, 42, .2);
    border-color: rgba(216, 53, 42, .5);
  }
  /* Story 6.3 — the light amber tint washes out on the dark card. */
  :root[data-theme='dark'] .badge-status--draft-newer {
    color: #F2A93B;
    background: rgba(242, 169, 59, .16);
  }
  :root[data-theme='dark'] .cand-detail > td {
    background: rgba(242, 169, 59, .05);
  }
  /* Curator controls — the light gold gradient washes out on the dark card (btn-gold guard).
     --color-primary-foreground / --color-danger are already theme-aware, so only the
     literal gradients + rgba borders need a dark override. */
  :root[data-theme='dark'] .cand-btn--gold,
  :root[data-theme='dark'] .cand-btn--path-active {
    background: linear-gradient(#F2A93B, #E0962A);
    text-shadow: none;
  }
  :root[data-theme='dark'] .cand-btn--gold:hover:not(:disabled),
  :root[data-theme='dark'] .cand-btn--path-active:hover:not(:disabled) {
    background: linear-gradient(#E0962A, #C9781F);
  }
  :root[data-theme='dark'] .cand-btn--danger {
    border-color: rgba(242, 88, 77, .5);
  }
  :root[data-theme='dark'] .cand-btn--danger:hover:not(:disabled) {
    background: rgba(242, 88, 77, .12);
  }
  /* Story 5.6 — the light danger tints + parchment washes need dark overrides. */
  :root[data-theme='dark'] .cand-flag--divergent,
  :root[data-theme='dark'] .cand-flag-chip {
    color: var(--color-danger);
    background: rgba(216, 53, 42, .2);
    border-color: rgba(216, 53, 42, .5);
  }
  :root[data-theme='dark'] .cand-linkpanel {
    background: rgba(242, 169, 59, .05);
  }
  :root[data-theme='dark'] .cand-select {
    background: var(--color-surface);
  }
  /* Story 5.7 — the light parchment/white literals + the teal chip tint need dark variants
     (--color-accent already swaps teal → royal-blue; --color-primary/--color-muted are theme-aware). */
  :root[data-theme='dark'] .cap-strip {
    background: linear-gradient(var(--color-surface), var(--color-bg));
    box-shadow: 0 6px 18px rgba(0, 0, 0, .3);
  }
  :root[data-theme='dark'] .cap-counter {
    background: rgba(255, 255, 255, .03);
  }
  :root[data-theme='dark'] .badge-carryover {
    color: var(--color-success);
    background: rgba(95, 227, 148, .14);
  }
  /* Story 5.8 — the success-green carry-over pill washes out on the dark card. */
  :root[data-theme='dark'] .cand-cleared-pill {
    color: var(--color-success);
    background: rgba(95, 227, 148, .14);
  }

  /* ===== Mobile — the shell is usable on the bottom-bar layout too. ===== */
  @media (max-width: 767.98px) {
    .shell-head {
      padding: var(--space-3) var(--space-4);
    }
    .role-chips {
      width: 100%;
      margin-left: 0;
      order: 3;
    }
  }
</style>

<script>
  /*
    /admin client logic — a bundled module (not is:inline: it imports the SDK helpers).
    Resolves the session + access client-side, then builds the role chip and the tab strip
    (tabs are BUILT from accessible areas → inaccessible ones are absent, not disabled).
    Nothing security-relevant is enforced here; Directus returns 401/403 regardless (AD-4).
  */
  import {
    getCurrentUser,
    getAdminAccess,
    getMyPermissions,
    getCandidates,
    getActivePeriod,
    updateCandidate,
    updateCandidates,
    createGroup,
    deleteGroup,
    deleteCandidate,
    deleteCandidates,
    getAlliances,
    getGuideDrafts,
    getGuideDraft,
    getPublishedGuides,
    publishGuide,
    logout,
    DATA_STUDIO_URL,
  } from '../../lib/directus';
  import type {
    Candidate,
    CandidatePatch,
    AllianceOption,
    TransferPeriod,
    GuideDraft,
    PublishedGuide,
  } from '../../lib/directus';

  interface AreaDef {
    key: string; // the /permissions/me collection key
    area: string; // chip word (Transfer/Guides/Alliances/Accounts)
    label: string; // tab label
    icon: string;
    ownerOnly?: boolean;
  }

  // The four conceptual admin areas. Candidates (Transfer) and — since Story 6.3 — the
  // Guides publish list are custom surfaces (panelBody branches on `key`); the rest hand
  // off to the Data Studio. Guides AUTHORING stays in the Studio (AD-3): the custom panel
  // is only the minimal publish surface (the Option-B "Owner-blessed helper", Sabo
  // 2026-07-16 — a recorded deviation from the one-custom-surface letter of AR-5).
  // Accounts is Owner-only.
  const AREAS: AreaDef[] = [
    { key: 'candidates', area: 'Transfer', label: 'Candidates', icon: 'clipboard' },
    { key: 'guides', area: 'Guides', label: 'Guides', icon: 'book-open' },
    { key: 'alliances', area: 'Alliances', label: 'Alliances', icon: 'building-2' },
    { key: 'directus_users', area: 'Accounts', label: 'Accounts', icon: 'crown', ownerOnly: true },
  ];

  const loadingEl = document.getElementById('admin-loading');
  const errorEl = document.getElementById('admin-error');
  const emptyEl = document.getElementById('admin-empty');
  const shellEl = document.getElementById('admin-shell');
  const chipsEl = document.getElementById('role-chips');
  const tabsEl = document.getElementById('admin-tabs');
  const panelsEl = document.getElementById('admin-panels');

  function showOnly(el: HTMLElement | null) {
    for (const s of [loadingEl, errorEl, emptyEl, shellEl]) {
      if (s) s.hidden = s !== el;
    }
  }

  // A 401/403 = a real auth rejection (not signed in / forbidden). Anything else — server
  // down, CORS/URL mismatch — is a reachability failure, NOT a sign-out.
  function authRejected(err: unknown): boolean {
    const status = (err as { response?: { status?: number } })?.response?.status;
    return status === 401 || status === 403;
  }

  const svg = (name: string): string => {
    // Minimal inline-Lucide echo of the shared Icon component (currentColor, 1em). Path
    // strings mirror src/components/Icon.astro; kept in sync there.
    const paths: Record<string, string> = {
      clipboard:
        '<rect width="8" height="4" x="8" y="2" rx="1" ry="1" /><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />',
      'book-open':
        '<path d="M12 7v14" /><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" />',
      'building-2':
        '<path d="M10 12h4" /><path d="M10 8h4" /><path d="M14 21v-3a2 2 0 0 0-4 0v3" /><path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2" /><path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16" />',
      crown:
        '<path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" />',
      'arrow-up-right': '<path d="M7 7h10v10" /><path d="M7 17 17 7" />',
      'triangle-alert':
        '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3" /><path d="M12 9v4" /><path d="M12 17h.01" />',
    };
    return `<svg class="icon" viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">${paths[name] ?? ''}</svg>`;
  };

  interface ResolvedArea extends AreaDef {
    mode: string; // chip mode word: Read | Work | all
  }

  // Normalize /permissions/me (handle both raw and {data:...}) and decide, per area,
  // whether it is accessible and at what mode.
  function resolveNonOwnerAreas(perms: unknown): ResolvedArea[] {
    const raw = perms as { data?: unknown } | null;
    const map = ((raw && (raw.data ?? raw)) || {}) as Record<
      string,
      Record<string, { access?: string } | undefined> | undefined
    >;
    const has = (entry: { access?: string } | undefined) =>
      !!entry && entry.access !== undefined && entry.access !== 'none';

    const out: ResolvedArea[] = [];
    for (const a of AREAS) {
      if (a.ownerOnly) continue; // Accounts is Owner-only; a non-Owner never sees it
      const c = map[a.key];
      if (!c) continue; // no entry → no grant → tab absent
      const canRead = has(c.read);
      const canWrite = has(c.create) || has(c.update) || has(c.delete);
      if (!canRead && !canWrite) continue;
      out.push({ ...a, mode: canWrite ? 'Work' : 'Read' });
    }
    return out;
  }

  function renderChips(areas: ResolvedArea[], isOwner: boolean) {
    if (!chipsEl) return;
    chipsEl.textContent = '';
    const labels = isOwner ? ['Owner · all'] : areas.map((a) => `${a.area} · ${a.mode}`);
    for (const text of labels) {
      const chip = document.createElement('span');
      chip.className = 'role-chip';
      const dot = document.createElement('span');
      dot.className = 'dot';
      dot.setAttribute('aria-hidden', 'true');
      chip.append(dot, document.createTextNode(text)); // textContent path — no innerHTML for the label
      chipsEl.append(chip);
    }
  }

  function panelBody(area: AreaDef): string {
    if (area.key === 'candidates') {
      // Trusted CONSTANTS only (frame + states). Candidate ROWS are built later with
      // textContent/createElement in renderCandidateTable — never innerHTML with user data.
      return `<h2>Candidates</h2>
<div class="cand-state" id="cand-loading" role="status"><p class="muted">Loading candidates…</p></div>
<div class="cand-state" id="cand-error" hidden><p class="admin-msg" role="alert">Couldn’t load the candidate list. Please try again.</p><button type="button" class="btn-gold btn-narrow" id="cand-retry">Retry</button></div>
<div class="cand-state" id="cand-empty" hidden><p class="muted">No candidates yet — applications will appear here as they come in.</p></div>
<div class="cand-table-wrap" id="cand-table-wrap" hidden></div>`;
    }
    if (area.key === 'guides') {
      // Trusted CONSTANTS only. Guide ROWS are built with textContent in renderGuidesTable —
      // draft body HTML is NEVER rendered here (the 6.4 public reader owns sanitize+render).
      return `<h2>Guides</h2>
<p class="cand-intro">Published changes reach the public site after ~1–3 min.</p>
<div class="cand-state" id="guides-loading" role="status"><p class="muted">Loading guides…</p></div>
<div class="cand-state" id="guides-error" hidden><p class="admin-msg" role="alert">Couldn’t load the guides list. Please try again.</p><button type="button" class="btn-gold btn-narrow" id="guides-retry">Retry</button></div>
<div class="cand-state" id="guides-empty" hidden><p class="muted">No guide drafts yet — Editors author drafts in the Data Studio and they appear here for review.</p><a class="btn-gold" href="${DATA_STUDIO_URL}" target="_blank" rel="noopener noreferrer">Open the Data Studio ${svg('arrow-up-right')}</a></div>
<div class="cand-table-wrap" id="guides-table-wrap" hidden></div>
<p class="guides-studio-note"><a href="${DATA_STUDIO_URL}" target="_blank" rel="noopener noreferrer">Write drafts in the Data Studio</a></p>`;
    }
    const owner = area.ownerOnly ? ' (Owner only)' : '';
    return `<h2>${area.label}</h2><p>${area.area}${owner} is managed in the Data Studio.</p><a class="btn-gold" href="${DATA_STUDIO_URL}" target="_blank" rel="noopener noreferrer">Open the Data Studio ${svg('arrow-up-right')}</a>`;
  }

  function selectTab(index: number, tabs: HTMLButtonElement[], panels: HTMLElement[]) {
    tabs.forEach((t, i) => {
      const on = i === index;
      t.setAttribute('aria-selected', on ? 'true' : 'false');
      t.tabIndex = on ? 0 : -1;
      if (panels[i]) panels[i].hidden = !on;
    });
  }

  function renderShell(areas: AreaDef[]) {
    if (!tabsEl || !panelsEl) return;
    tabsEl.textContent = '';
    panelsEl.textContent = '';
    const tabs: HTMLButtonElement[] = [];
    const panels: HTMLElement[] = [];

    areas.forEach((a, i) => {
      const tab = document.createElement('button');
      tab.type = 'button';
      tab.className = 'tab';
      tab.setAttribute('role', 'tab');
      tab.id = `tab-${a.key}`;
      tab.setAttribute('aria-controls', `panel-${a.key}`);
      tab.innerHTML = `${svg(a.icon)}<span>${a.label}</span>`;

      const panel = document.createElement('section');
      panel.className = 'panel';
      panel.setAttribute('role', 'tabpanel');
      panel.id = `panel-${a.key}`;
      panel.setAttribute('aria-labelledby', `tab-${a.key}`);
      panel.tabIndex = 0; // focusable so a keyboard user can reach a text-only panel (e.g. Candidates)
      panel.innerHTML = panelBody(a); // trusted constants only (no user data)

      tab.addEventListener('click', () => selectTab(i, tabs, panels));
      if (a.key === 'candidates') tab.addEventListener('click', () => maybeLoadCandidates());
      if (a.key === 'guides') tab.addEventListener('click', () => maybeLoadGuides());
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const next = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
        selectTab(next, tabs, panels);
        if (areas[next]?.key === 'candidates') maybeLoadCandidates(); // keyboard activation must load too (mirrors the click + boot triggers)
        if (areas[next]?.key === 'guides') maybeLoadGuides();
        tabs[next].focus();
      });

      tabs.push(tab);
      panels.push(panel);
      tabsEl.append(tab);
      panelsEl.append(panel);
    });

    selectTab(0, tabs, panels); // default to the first accessible tab (Candidates if present)
    if (areas[0]?.key === 'candidates') maybeLoadCandidates(); // lazy-load if Candidates is initial
    if (areas[0]?.key === 'guides') maybeLoadGuides(); // a Guides-only leader lands here (Story 6.3)
  }

  // ===== Candidates panel (Story 5.4) — lazy-loaded, read-only calm table =====
  // Runtime session-authenticated read; a Viewer sees ALL fields (whole-collection read).
  // All candidate data enters the DOM via textContent/createElement (XSS: untrusted PII).
  // Story 5.5: a Curator (Transfer·Work) or the Owner also gets per-row status/path controls.
  let canWriteCandidates = false; // set in boot() from the resolved Transfer mode / Owner
  // Story 5.6: the fetched rows are held module-wide so grouping/suggested writes can mutate
  // them in place and trigger a table-wide recompute (the divergent flag + accents are a
  // membership-wide derivation, not a single-row one). openDetails preserves which rows are
  // expanded across a full re-render, so a Curator's working row stays open after a write.
  let candidateRows: Candidate[] = [];
  const openDetails = new Set<number>();
  let alliancesCache: AllianceOption[] | null = null; // the suggested-alliance picker source (lazy)
  // Story 5.8: the reachability toggle. 5.7's active-window scoping hides prior-window still-Applied
  // rows (period ≠ active, not Accepted → not a carry-over), making them un-actionable for delete /
  // cleanup. When on, the table renders the un-scoped set so a Curator can reach + clear them. Off by
  // default → the calm active-window view (5.7) stays the default (never permanently broadens scope).
  let showClosedWindow = false;
  // Story 5.8: the between-windows cleanup confirmation (the mockup .cleared card). Set to the number
  // of rows the last cleanup removed; the "carried forward" count is recomputed LIVE at render (never
  // stale). null = no notice. Cleared on a fresh load / a later per-row delete / dismiss.
  let cleanupNotice: { cleared: number } | null = null;
  // Story 5.7: the single active transfer window (caps for the counter denominators + the id for
  // active-window scoping / carry-over derivation). Fetched once alongside candidates. null = no
  // active window OR a transient caps-read failure — the two are told apart by capsReadError so the
  // strip degrades calmly (denominators "—", counts kept) instead of freezing at n/0 (Task 6).
  let activePeriod: TransferPeriod | null = null;
  let capsReadError = false;
  // Story 5.6 (review P3): one guard for ALL candidate writes (5.5 per-row + 5.6 table-wide).
  // A 5.6 write rebuilds the whole tbody, so writes must serialize — otherwise a rerender could
  // detach another row's in-flight write (silent failure) or a rebuilt panel be re-clicked mid-write.
  let writeInFlight = false;
  const STATUS_MOD: Record<string, string> = {
    Applied: 'applied',
    Accepted: 'accepted',
    Transferred: 'transferred',
    Rejected: 'rejected',
  };

  function showCandState(which: 'loading' | 'error' | 'empty' | 'table') {
    const map: Record<string, string> = {
      loading: 'cand-loading',
      error: 'cand-error',
      empty: 'cand-empty',
      table: 'cand-table-wrap',
    };
    for (const [key, elId] of Object.entries(map)) {
      const el = document.getElementById(elId);
      if (el) el.hidden = key !== which;
    }
  }

  const yesNo = (v: boolean): string => (v ? 'Yes' : 'No');
  const dash = (v: string | null | undefined): string => {
    const s = (v ?? '').trim();
    return s === '' ? '—' : s;
  };

  // Raw power → "135.5M" (one decimal only when fractional); null = row predates the column.
  const fmtPower = (raw: number | null | undefined): string => {
    if (raw == null || !Number.isFinite(raw)) return '—';
    const m = raw / 1_000_000;
    return (Number.isInteger(m) ? String(m) : m.toFixed(1)) + 'M';
  };

  function td(text: string, className?: string): HTMLTableCellElement {
    const cell = document.createElement('td');
    if (className) cell.className = className;
    cell.textContent = text; // user data → textContent, never innerHTML
    return cell;
  }

  function statusChip(status: string): HTMLElement {
    const chip = document.createElement('span');
    chip.className = `badge-status badge-status--${STATUS_MOD[status] ?? 'applied'}`;
    chip.textContent = status || '—'; // the word carries meaning beyond colour (a11y)
    return chip;
  }

  function specialBadge(): HTMLElement {
    const b = document.createElement('span');
    b.className = 'badge-special-chip';
    b.innerHTML = svg('triangle-alert'); // trusted constant SVG
    b.append(document.createTextNode('Special invitation')); // verbatim jargon
    return b;
  }

  // Divergent group = a group with ≥2 distinct non-null suggested alliances, derived at the
  // edge over the single fetch (AR-6; no transfer_groups read needed — group id + suggested
  // id are both on the candidate rows). Inert until Story 5.6 populates groups/suggestions.
  function computeDivergentGroups(rows: Candidate[]): Set<number> {
    const byGroup = new Map<number, Set<number>>();
    for (const r of rows) {
      const gid = r.group;
      const sid = r.suggested_alliance?.id ?? null;
      if (gid == null || sid == null) continue;
      if (!byGroup.has(gid)) byGroup.set(gid, new Set());
      byGroup.get(gid)!.add(sid);
    }
    const out = new Set<number>();
    for (const [gid, set] of byGroup) if (set.size >= 2) out.add(gid);
    return out;
  }

  // ===== Active-window scoping + capacity counters (Story 5.7) — pure edge computations =====
  // Everything the cap-strip shows is derived from the single getCandidates fetch + the active
  // period's LIVE caps — no stored counter, no `carry` field, recomputed every render (AR-6/AD-4).
  // Kept pure so they are unit-testable in isolation.

  // The active-window set: a candidate is in-window iff it belongs to the active period OR is
  // Accepted. An Accepted row from a PRIOR window is a carry-over that still occupies a slot, so it
  // must not silently drop out of the next window's counts (AD-17). One status per row, so
  // "Accepted AND not Transferred" reduces to status === 'Accepted' and each row appears once (no
  // manual OR-branch dedupe needed). period == null (no active window / caps-read failure) →
  // degrade to ALL rows so the table never goes blank.
  function activeWindowRows(rows: Candidate[], period: TransferPeriod | null): Candidate[] {
    if (period == null) return rows;
    return rows.filter((r) => r.period === period.id || r.status === 'Accepted');
  }

  // Carry-over = an Accepted candidate stamped with a period that is no longer the active one. The
  // period stamp is immutable (AD-17 — never re-stamped), so this is a safe derivation, never a write.
  function isCarryOver(r: Candidate, period: TransferPeriod | null): boolean {
    return period != null && r.status === 'Accepted' && r.period !== period.id;
  }

  // Sort a COPY so carried-over rows surface first, then the rest in the incoming -id order. Relies
  // on Array.prototype.sort being stable (ES2019+; guaranteed in every target browser + Node 22).
  function sortForWindow(rows: Candidate[], period: TransferPeriod | null): Candidate[] {
    return [...rows].sort(
      (a, b) => Number(isCarryOver(b, period)) - Number(isCarryOver(a, period)),
    );
  }

  interface CapCounters {
    invitePlanned: number;
    specialPlanned: number;
    randomAsk: number;
    acceptedNoPath: number;
    invitedCap: number | null;
    specialCap: number | null;
  }

  // Bucket the ACTIVE-WINDOW set by planned_path (carried Accepted rows included, so they keep
  // counting toward the caps they occupy — AD-17). Caps come LIVE off the active period row, never a
  // literal (AC-2 — the special target is never a hardcoded 3); null when no active window / the caps
  // read failed → the card renders a "—" denominator (Task 6), never n/0.
  function computeCounters(windowRows: Candidate[], period: TransferPeriod | null): CapCounters {
    let invitePlanned = 0;
    let specialPlanned = 0;
    let randomAsk = 0;
    let acceptedNoPath = 0;
    for (const r of windowRows) {
      // A Rejected candidate frees its slot — it is no longer planned, so it counts toward no bucket
      // (review 5.7 decision, Sabo 2026-07-14). Accepted + Transferred keep counting (a Transferred
      // row consumed the slot). Reachable via Accept-as-<path> → Reject (5.5 leaves planned_path stale).
      if (r.status === 'Rejected') continue;
      if (r.planned_path === 'Invite') invitePlanned++;
      else if (r.planned_path === 'Special') specialPlanned++;
      else if (r.planned_path === 'Random-ask') randomAsk++;
      // A raw-API-only occupied slot: Accepted but no planned_path (the UI Accept forces a path, so
      // this is normally absent). Surfaced only when N>0 so planning is not silently blind (OQ-3).
      if (r.status === 'Accepted' && !r.planned_path) acceptedNoPath++;
    }
    return {
      invitePlanned,
      specialPlanned,
      randomAsk,
      acceptedNoPath,
      invitedCap: period?.invited_cap ?? null,
      specialCap: period?.special_cap ?? null,
    };
  }

  // A calm white counter card: label + "value / cap". `cap` null → a "—" denominator (unknown /
  // caps-read failure). `editable` tints the value gold — the live-editable special target (AC-2).
  // Over-target counts (e.g. 36 / 35) render plainly, no red, no alarm — never an error (OQ-4).
  function counterCard(label: string, value: number, cap: number | null, editable: boolean): HTMLElement {
    const card = document.createElement('div');
    card.className = editable ? 'cap-counter cap-counter--editable' : 'cap-counter';
    const cl = document.createElement('div');
    cl.className = 'cap-cl';
    cl.textContent = label; // trusted constant label
    const cv = document.createElement('div');
    cv.className = 'cap-cv';
    cv.append(document.createTextNode(String(value))); // count → textContent, tabular-nums via CSS
    const denom = document.createElement('small');
    denom.textContent = ` / ${cap == null ? '—' : cap}`; // live cap, never a literal
    cv.append(denom);
    card.append(cl, cv);
    return card;
  }

  // The Random-ask card: a bare list count with no denominator — AR-19 removed the random counter,
  // the 20 random slots are out of scope (OQ-5). `random_cap` stays stored-but-unshown config.
  function randomCard(value: number): HTMLElement {
    const card = document.createElement('div');
    card.className = 'cap-counter';
    const cl = document.createElement('div');
    cl.className = 'cap-cl';
    cl.textContent = 'Random-ask';
    const cv = document.createElement('div');
    cv.className = 'cap-cv';
    cv.append(document.createTextNode(String(value)));
    const small = document.createElement('small');
    small.textContent = ' queued'; // list count, not a capacity ratio
    cv.append(small);
    card.append(cl, cv);
    return card;
  }

  // Success-tinted "Carry-over" badge (DESIGN: carry-over confirmation = success green, NOT danger,
  // NOT gold). Surfaced next to the name; the row is sorted to the top of the scoped list (AC-5).
  function carryOverBadge(): HTMLElement {
    const b = document.createElement('span');
    b.className = 'badge-carryover';
    b.textContent = 'Carry-over'; // trusted constant → textContent
    return b;
  }

  // The gold-framed capacity strip (Task 3): a "room" that frames three calm counter cards + the
  // teal planning-aid chip. Read surface for BOTH roles (Viewer read-only, Curator in Work mode) —
  // never gated. Rebuilt on every render so the counters recompute after each write (Task 5). role=
  // status keeps the a11y floor minimal (it recomputes after writes; the shell already uses it).
  function buildCapStrip(rows: Candidate[], period: TransferPeriod | null): HTMLElement {
    const c = computeCounters(activeWindowRows(rows, period), period);

    const strip = document.createElement('div');
    strip.className = 'cap-strip';
    strip.setAttribute('role', 'status');

    const title = document.createElement('div');
    title.className = 'cap-title';
    title.append(document.createTextNode('Capacity counters'));
    strip.append(title);

    const grid = document.createElement('div');
    grid.className = 'cap-counters';
    grid.append(counterCard('Invite-planned', c.invitePlanned, c.invitedCap, false));
    grid.append(counterCard('Special-planned', c.specialPlanned, c.specialCap, true)); // gold, live cap
    grid.append(randomCard(c.randomAsk));
    strip.append(grid);

    // A muted "Accepted · no path: N" line, only when N>0 (OQ-3) — surfaces an occupied slot that
    // sits in no planned_path bucket so planning is not silently blind. Never a gate.
    if (c.acceptedNoPath > 0) {
      const note = document.createElement('p');
      note.className = 'cap-strip-note';
      note.textContent = `Accepted · no path: ${c.acceptedNoPath}`;
      strip.append(note);
    }

    // No active window / caps unavailable — denominators already show "—"; add a calm note so the
    // "—" reads as a state, not a glitch. Never throws (unlike the build-time reader).
    if (period == null) {
      const note = document.createElement('p');
      note.className = 'cap-strip-note';
      note.textContent = capsReadError
        ? 'Couldn’t load the transfer window — counts shown across all applicants, targets unavailable.'
        : 'No active transfer window — counts shown across all applicants.';
      strip.append(note);
    }

    return strip;
  }

  // ===== Grouping + suggested-alliance (Story 5.6) — Work-mode only =====
  // Grouping links friends via candidates.group (M2O → transfer_groups); the suggested
  // alliance is written on candidates.suggested_alliance (candidate-level, or a group-level
  // ONE-TRANSACTION fan-out via updateCandidates). transfer_groups carries no suggested
  // column and the divergent flag is edge-computed, never stored (AR-6/AR-10). Every write
  // sends ONLY { group } / { suggested_alliance } — never `period`/public-core/desired (AD-8).

  const groupMembers = (rows: Candidate[], gid: number): Candidate[] =>
    rows.filter((r) => r.group === gid);

  // The count of DISTINCT non-null suggested alliances in a group — the "N" in the flag copy.
  function distinctSuggestionCount(rows: Candidate[], gid: number): number {
    const s = new Set<number>();
    for (const r of rows) {
      if (r.group === gid && r.suggested_alliance?.id != null) s.add(r.suggested_alliance.id);
    }
    return s.size;
  }

  // Lazy-load the alliance list once; a Curator already holds the free `alliances` read.
  async function ensureAlliances(): Promise<AllianceOption[]> {
    if (alliancesCache) return alliancesCache;
    try {
      alliancesCache = await getAlliances();
    } catch {
      // Review P1: do NOT cache [] on a transient failure — an empty array is truthy, so it
      // would poison the picker for the whole session (only a reload recovers). Leave the cache
      // null and return a transient empty list; the next ensureAlliances() call retries.
      return [];
    }
    return alliancesCache;
  }
  function allianceOptionFor(id: number): AllianceOption {
    return (alliancesCache ?? []).find((a) => a.id === id) ?? { id, name: null };
  }

  // Link r with the selected candidates. Reuse an existing group if any selected member (or r)
  // already belongs to one; otherwise mint a new transfer_groups row, then batch-stamp
  // candidates.group. Local rows are mutated so the table-wide re-render reflects it.
  async function linkGroup(r: Candidate, selectedIds: number[]): Promise<void> {
    if (selectedIds.length === 0) return; // review P2: need ≥1 other — never mint a group of one
    const memberIds = [r.id, ...selectedIds];
    let gid: number | null = r.group;
    if (gid == null) {
      for (const id of selectedIds) {
        const c = candidateRows.find((x) => x.id === id);
        if (c?.group != null) {
          gid = c.group;
          break;
        }
      }
    }
    if (gid == null) {
      const g = await createGroup();
      gid = g.id;
    }
    const toSet = memberIds.filter((id) => {
      const c = candidateRows.find((x) => x.id === id);
      return c != null && c.group !== gid;
    });
    // Review P4/D1: capture the source groups moved members are LEAVING (before the local
    // mutation) so we can dissolve any that drop below 2 — otherwise linking across groups
    // strands a lone remainder with a gold accent (the "no group of one" invariant, elsewhere
    // enforced by unlinkFromGroup, must hold here too).
    const sourceGids = new Set<number>();
    for (const id of toSet) {
      const c = candidateRows.find((x) => x.id === id);
      if (c?.group != null && c.group !== gid) sourceGids.add(c.group);
    }
    if (toSet.length > 0) {
      await updateCandidates(toSet, { group: gid });
      for (const id of toSet) {
        const c = candidateRows.find((x) => x.id === id);
        if (c) c.group = gid;
      }
    }
    for (const sgid of sourceGids) {
      const remaining = groupMembers(candidateRows, sgid);
      if (remaining.length === 1) {
        await updateCandidate(remaining[0].id, { group: null });
        remaining[0].group = null;
        await deleteGroup(sgid);
      } else if (remaining.length === 0) {
        await deleteGroup(sgid);
      }
    }
  }

  // Unlink r from its group. A group that drops below 2 members is dissolved (a lone member
  // is not a group; on_delete SET NULL un-links, never deletes candidates).
  async function unlinkFromGroup(r: Candidate): Promise<void> {
    const gid = r.group;
    if (gid == null) return;
    const others = groupMembers(candidateRows, gid).filter((m) => m.id !== r.id);
    await updateCandidate(r.id, { group: null });
    r.group = null;
    if (others.length === 1) {
      await updateCandidate(others[0].id, { group: null });
      others[0].group = null;
      await deleteGroup(gid);
    } else if (others.length === 0) {
      await deleteGroup(gid);
    }
  }

  // Write a suggested alliance to one candidate (candidate-level) or fan it out to a whole
  // group in ONE transaction (AC3). allianceId null clears it. Local rows are mutated with the
  // expanded {id,name} so the Suggested cell re-renders correctly.
  async function setSuggested(ids: number[], allianceId: number | null): Promise<void> {
    const expanded = allianceId == null ? null : allianceOptionFor(allianceId);
    if (ids.length === 1) {
      await updateCandidate(ids[0], { suggested_alliance: allianceId });
    } else {
      await updateCandidates(ids, { suggested_alliance: allianceId });
    }
    for (const id of ids) {
      const c = candidateRows.find((x) => x.id === id);
      if (c) c.suggested_alliance = expanded;
    }
  }

  // Re-render the whole table from the mutated in-memory rows (recomputes divergence + accents
  // + flags). openDetails keeps expanded rows open. No refetch — the load-once cache model.
  function rerenderCandidates() {
    renderCandidateTable(candidateRows);
    showCandState('table');
  }

  // ===== Manual delete + window cleanup (Story 5.8) — Work-mode only =====
  // Delete is a session-cookie DELETE (204). Removing the row from candidateRows + a rerender drops
  // it from the capacity counters (a pure edge recompute — AC-1 "stops counting") and prunes its
  // openDetails id for free. period is NEVER written (AD-17). The server 403s a Viewer's delete
  // (grant absent) — AC-4; the UI also hides the control (canWriteCandidates).

  // Dissolve any of the given groups that dropped below 2 members after a delete (a lone member is
  // not a group). Mirrors unlinkFromGroup's tail; on_delete SET NULL un-links, never deletes.
  async function dissolveIfUndersized(gids: Set<number>): Promise<void> {
    for (const gid of gids) {
      const remaining = groupMembers(candidateRows, gid);
      if (remaining.length === 1) {
        await updateCandidate(remaining[0].id, { group: null });
        remaining[0].group = null;
        await deleteGroup(gid);
      } else if (remaining.length === 0) {
        await deleteGroup(gid);
      }
    }
  }

  // Delete one candidate (any status, any window). Removes it from the in-memory source of truth,
  // prunes its expansion id, and dissolves its group if the delete leaves a singleton (Task 4).
  async function deleteCandidateRow(r: Candidate): Promise<void> {
    const gid = r.group;
    cleanupNotice = null; // a fresh destructive action supersedes a stale cleanup confirmation
    await deleteCandidate(r.id);
    candidateRows = candidateRows.filter((x) => x.id !== r.id);
    openDetails.delete(r.id);
    if (gid != null) await dissolveIfUndersized(new Set([gid]));
  }

  // The between-windows cleanup (AC-2): delete EVERY terminal row (Transferred / Rejected), across
  // all windows (OQ-3 — terminal rows never carry over, so window-scoping the delete adds nothing).
  // Accepted rows are NEVER selected (AD-17) — they carry forward automatically. Returns the number
  // of rows cleared (0 → nothing to do). Dissolves any group left below 2 by the batch.
  async function runCleanup(): Promise<number> {
    const terminal = candidateRows.filter(
      (r) => r.status === 'Transferred' || r.status === 'Rejected',
    );
    if (terminal.length === 0) return 0;
    const ids = terminal.map((r) => r.id);
    const gids = new Set<number>();
    for (const r of terminal) if (r.group != null) gids.add(r.group);
    await deleteCandidates(ids);
    const idSet = new Set(ids);
    candidateRows = candidateRows.filter((r) => !idSet.has(r.id));
    for (const id of ids) openDetails.delete(id);
    await dissolveIfUndersized(gids);
    return ids.length;
  }

  // The Curator toolbar above the table (Story 5.8): the batch "clear transferred/rejected" action +
  // the "show closed-window applicants" reachability toggle. Gated on canWriteCandidates (a Viewer
  // never sees it). Rebuilt every render so the terminal count + toggle state stay live.
  function buildCandToolbar(rows: Candidate[]): HTMLElement {
    const bar = document.createElement('div');
    bar.className = 'cand-toolbar';

    // --- Window cleanup: clear ALL terminal rows (Transferred / Rejected), any window (OQ-3).
    const terminalCount = rows.filter(
      (r) => r.status === 'Transferred' || r.status === 'Rejected',
    ).length;
    const cleanup = document.createElement('div');
    cleanup.className = 'cand-cleanup';
    const cleanupMsg = document.createElement('p');
    cleanupMsg.className = 'cand-action-msg';
    cleanupMsg.setAttribute('role', 'alert');
    cleanupMsg.hidden = true;

    if (terminalCount === 0) {
      const none = document.createElement('span');
      none.className = 'cand-toolbar-note';
      none.textContent = 'Nothing to clear — no transferred or rejected candidates.';
      cleanup.append(none);
    } else {
      const row = document.createElement('div');
      row.className = 'cand-action-row';
      const trigger = candButton(`Clear transferred/rejected (${terminalCount})`, 'danger');

      // The guarded batch: serialize via writeInFlight, delete the terminal rows, then rerender.
      // On success set the .cleared confirmation (AC-3); 401/403 → session lapsed → /leader.
      const doCleanup = () => {
        if (writeInFlight) return;
        writeInFlight = true;
        const controls = Array.from(bar.querySelectorAll('button, input')) as (
          | HTMLButtonElement
          | HTMLInputElement
        )[];
        const prevDisabled = controls.map((c) => c.disabled);
        controls.forEach((c) => (c.disabled = true));
        cleanupMsg.hidden = true;
        cleanupMsg.textContent = '';
        runCleanup()
          .then((n) => {
            if (n > 0) cleanupNotice = { cleared: n };
            rerenderCandidates();
          })
          .catch((err) => {
            if (authRejected(err)) {
              window.location.replace('/leader');
              return;
            }
            cleanupMsg.hidden = false; // reveal the role="alert" region BEFORE writing text
            cleanupMsg.textContent = 'Couldn’t clear the list. Please try again.';
            controls.forEach((c, i) => (c.disabled = prevDisabled[i]));
          })
          .finally(() => {
            writeInFlight = false;
          });
      };
      const restore = () => {
        row.textContent = '';
        row.append(trigger);
      };
      trigger.addEventListener('click', () => {
        row.textContent = '';
        const q = document.createElement('span');
        q.className = 'cand-action-label';
        q.textContent = `Clear ${terminalCount} transferred/rejected candidate${
          terminalCount === 1 ? '' : 's'
        }? Accepted candidates are kept. This can’t be undone.`;
        const yes = candButton('Clear them', 'danger');
        yes.addEventListener('click', doCleanup);
        const no = candButton('Cancel', 'path');
        no.addEventListener('click', restore);
        row.append(q, yes, no);
      });
      row.append(trigger);
      cleanup.append(row);
    }
    cleanup.append(cleanupMsg);
    bar.append(cleanup);

    // --- Reachability toggle: reveal prior-window (closed) applicants that 5.7 scopes out (Task 6).
    const tog = document.createElement('label');
    tog.className = 'cand-toggle';
    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.checked = showClosedWindow;
    cb.addEventListener('change', () => {
      // A rerender while another candidate write is in flight would detach that write's
      // error UI (its msg/controls nodes) → silent failure (the L1155 hazard). Ignore the
      // flip until the write settles; revert the visual state so it doesn't lie.
      if (writeInFlight) {
        cb.checked = showClosedWindow;
        return;
      }
      showClosedWindow = cb.checked;
      rerenderCandidates();
    });
    const tlab = document.createElement('span');
    tlab.textContent = 'Show closed-window applicants';
    tog.append(cb, tlab);
    bar.append(tog);

    return bar;
  }

  // The between-windows cleanup confirmation (Story 5.8, AC-3) — the mockup .cleared card: a calm
  // dashed-border card with a success-green carry-over pill. "cleared" is the last cleanup's count;
  // "carried forward" is recomputed LIVE (Accepted rows, which cleanup never touches — AD-17) so it
  // never goes stale. Dismissable.
  function buildClearedNotice(): HTMLElement {
    const carried = candidateRows.filter((r) => r.status === 'Accepted').length;
    const card = document.createElement('div');
    card.className = 'cand-cleared';

    const dismiss = document.createElement('button');
    dismiss.type = 'button';
    dismiss.className = 'cand-cleared-dismiss';
    dismiss.setAttribute('aria-label', 'Dismiss');
    dismiss.textContent = '×';
    dismiss.addEventListener('click', () => {
      // Don't rerender mid-write — it would detach an in-flight write's error UI (L1155 hazard).
      if (writeInFlight) return;
      cleanupNotice = null;
      rerenderCandidates();
    });

    const head = document.createElement('div');
    head.className = 'cand-cleared-head';
    head.textContent = 'List cleared';

    const body = document.createElement('p');
    body.className = 'cand-cleared-body';
    body.textContent =
      'Terminal candidates were cleared for the next event. Anyone marked Accepted but not transferred was carried forward automatically.';

    const counts = document.createElement('p');
    counts.className = 'cand-cleared-counts';
    counts.textContent = `${cleanupNotice?.cleared ?? 0} cleared · ${carried} carried forward`;

    const pill = document.createElement('span');
    pill.className = 'cand-cleared-pill';
    pill.textContent = 'Accepted-not-transferred carried to next event';

    card.append(dismiss, head, body, counts, pill);
    return card;
  }

  // ===== Curator status-lifecycle controls (Story 5.5) — Work-mode only =====
  // The legal transition graph is CLIENT-GUIDED only (AR-9/AD-7): no Directus Flow/hook
  // encodes it. The server enforces only WHO may write (Curator 200 / Viewer 403). Every
  // payload carries ONLY { status } / { planned_path } — never `period` (a re-stamp is
  // silent carry-over corruption, AD-17), never the public-core / desired_alliance fields.

  // planned_path: [stored enum value, display label]. Value 'Special' shows as 'Special invite'.
  const PLANNED_PATHS: [string, string][] = [
    ['Invite', 'Invite'],
    ['Special', 'Special invite'],
    ['Random-ask', 'Random-ask'],
  ];

  type CandAction = 'accept' | 'editPath' | 'transfer' | 'reject';
  // Applied → Accept (requires a path) · Mark Transferred (the Random exception) · Reject.
  // Accepted → edit path · Mark Transferred · Reject. Transferred / Rejected are terminal.
  function allowedActions(status: string): CandAction[] {
    switch (status) {
      case 'Applied':
        return ['accept', 'transfer', 'reject'];
      case 'Accepted':
        return ['editPath', 'transfer', 'reject'];
      default:
        return [];
    }
  }

  function candButton(label: string, variant: string): HTMLButtonElement {
    const b = document.createElement('button');
    b.type = 'button';
    b.className = `cand-btn cand-btn--${variant}`;
    b.textContent = label; // trusted constant labels (plain verbs, UX-DR-21)
    return b;
  }

  // A labelled row of the three planned-path buttons; `current` marks the active one when
  // editing an already-Accepted candidate.
  function pathGroup(label: string, current: string | null, onPick: (value: string) => void): HTMLElement {
    const row = document.createElement('div');
    row.className = 'cand-action-row';
    const lab = document.createElement('span');
    lab.className = 'cand-action-label';
    lab.textContent = label;
    row.append(lab);
    for (const [value, text] of PLANNED_PATHS) {
      const active = current === value;
      const b = candButton(text, active ? 'path-active' : 'path');
      b.setAttribute('aria-pressed', active ? 'true' : 'false');
      if (active) {
        b.disabled = true; // already the current path — clicking it would be a redundant no-op write
      } else {
        b.addEventListener('click', () => onPick(value));
      }
      row.append(b);
    }
    return row;
  }

  // Compact danger marker for a divergent member's Suggested cell (the full sentence + count
  // lives in the detail flag). Icon + text = meaning beyond colour.
  function divergentChip(): HTMLElement {
    const b = document.createElement('span');
    b.className = 'cand-flag-chip';
    b.innerHTML = svg('triangle-alert'); // trusted constant SVG
    b.append(document.createTextNode('Set one'));
    b.title = 'Group has different suggested alliances — set one';
    return b;
  }

  // Suggested-alliance control (Story 5.6). Candidate-level for a lone row; for a grouped row
  // the scope choice (this candidate vs whole group) honours FR-8 and drives the divergence
  // resolution ("Set for whole group" is the atomic fan-out that clears the flag).
  function buildSuggestSection(r: Candidate, runTable: (a: () => Promise<void>) => void): HTMLElement {
    const container = document.createElement('div');
    container.className = 'cand-suggest-section';

    const row = document.createElement('div');
    row.className = 'cand-action-row';
    const lab = document.createElement('span');
    lab.className = 'cand-action-label';
    lab.textContent = 'Suggested alliance';
    const select = document.createElement('select');
    select.className = 'cand-select';
    select.setAttribute('aria-label', `Suggested alliance for ${r.character_name}`);
    const none = document.createElement('option');
    none.value = '';
    none.textContent = '— none —';
    select.append(none);
    for (const a of alliancesCache ?? []) {
      const o = document.createElement('option');
      o.value = String(a.id);
      o.textContent = a.name ?? `#${a.id}`; // alliance name → textContent (XSS)
      select.append(o);
    }
    select.value = r.suggested_alliance?.id != null ? String(r.suggested_alliance.id) : '';
    row.append(lab, select);
    container.append(row);

    const parseSel = (): number | null => (select.value === '' ? null : Number(select.value));

    const btnRow = document.createElement('div');
    btnRow.className = 'cand-action-row';
    if (r.group != null) {
      const n = groupMembers(candidateRows, r.group).length;
      const thisBtn = candButton('Set for this candidate', 'path');
      thisBtn.addEventListener('click', () => runTable(() => setSuggested([r.id], parseSel())));
      const groupBtn = candButton(`Set for whole group (${n})`, 'gold');
      groupBtn.addEventListener('click', () =>
        runTable(() => setSuggested(groupMembers(candidateRows, r.group as number).map((m) => m.id), parseSel())),
      );
      btnRow.append(thisBtn, groupBtn);
    } else {
      const setBtn = candButton('Set suggested', 'gold');
      setBtn.addEventListener('click', () => runTable(() => setSuggested([r.id], parseSel())));
      btnRow.append(setBtn);
    }
    container.append(btnRow);
    return container;
  }

  // Group-linking control (Story 5.6). Grouped → Unlink; ungrouped → a "Link group…" toggle
  // revealing a checklist of the other candidates. Membership is shown read-only in the detail
  // summary above, so this block is just the actions.
  function buildGroupSection(r: Candidate, runTable: (a: () => Promise<void>) => void): HTMLElement {
    const sec = document.createElement('div');
    sec.className = 'cand-action-row';
    const lab = document.createElement('span');
    lab.className = 'cand-action-label';
    lab.textContent = 'Group';
    sec.append(lab);

    if (r.group != null) {
      const unlink = candButton('Unlink', 'path');
      unlink.addEventListener('click', () => runTable(() => unlinkFromGroup(r)));
      sec.append(unlink);
      return sec;
    }

    const container = document.createElement('div');
    container.className = 'cand-group-section';
    const linkBtn = candButton('Link group…', 'path');
    sec.append(linkBtn);

    const panel = document.createElement('div');
    panel.className = 'cand-linkpanel';
    panel.hidden = true;

    const list = document.createElement('div');
    list.className = 'cand-linklist';
    const checked = new Set<number>();
    const confirm = candButton('Link selected', 'gold');
    confirm.disabled = true;
    for (const c of candidateRows.filter((x) => x.id !== r.id)) {
      const opt = document.createElement('label');
      opt.className = 'cand-linkopt';
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.value = String(c.id);
      cb.addEventListener('change', () => {
        if (cb.checked) checked.add(c.id);
        else checked.delete(c.id);
        confirm.disabled = checked.size === 0;
      });
      const name = document.createElement('span');
      name.textContent = c.character_name; // candidate data → textContent (XSS)
      opt.append(cb, name);
      if (c.group != null) {
        const note = document.createElement('span');
        note.className = 'muted';
        note.textContent = ' (in a group)';
        opt.append(note);
      }
      list.append(opt);
    }

    const acts = document.createElement('div');
    acts.className = 'cand-action-row';
    const cancel = candButton('Cancel', 'path');
    cancel.addEventListener('click', () => {
      panel.hidden = true;
    });
    confirm.addEventListener('click', () => runTable(() => linkGroup(r, Array.from(checked))));
    acts.append(confirm, cancel);
    panel.append(list, acts);

    linkBtn.addEventListener('click', () => {
      panel.hidden = !panel.hidden;
    });

    container.append(sec, panel);
    return container;
  }

  // Build the action controls for one candidate row. Status/path writes (5.5) re-render the row
  // in place via `onDone`; grouping/suggested writes (5.6) re-render the whole table (the
  // divergent flag + accents are a membership-wide derivation), preserving expanded rows.
  function buildActions(r: Candidate, onDone: () => void): HTMLElement {
    const box = document.createElement('div');
    box.className = 'cand-actions';
    const head = document.createElement('div');
    head.className = 'cand-actions-head';
    head.textContent = 'Actions';
    box.append(head);

    const msg = document.createElement('p');
    msg.className = 'cand-action-msg';
    msg.setAttribute('role', 'alert');
    msg.hidden = true;

    // Status/path writes (5.5) — per-row in-place refresh. Shares the module-level writeInFlight
    // guard with the 5.6 table-wide writes so no two candidate writes overlap (review P3).
    const run = (patch: CandidatePatch) => {
      if (writeInFlight) return; // guard the double-click window + cross-row concurrency
      writeInFlight = true;
      writeCandidate(r, patch, box, msg, onDone).finally(() => {
        writeInFlight = false;
      });
    };
    // Grouping/suggested writes (5.6) — table-wide recompute (divergence is membership-wide).
    const runTable = (action: () => Promise<void>) => {
      if (writeInFlight) return;
      writeInFlight = true;
      const controls = Array.from(box.querySelectorAll('button, select')) as (
        | HTMLButtonElement
        | HTMLSelectElement
      )[];
      // Review P2: snapshot each control's disabled state so the error path restores it EXACTLY.
      // A blanket re-enable would revive the disabled-by-design active path button (no listener →
      // a dead enabled button) and the 0-checked "Link selected" confirm (→ a group of one).
      const prevDisabled = controls.map((c) => c.disabled);
      controls.forEach((c) => (c.disabled = true));
      msg.hidden = true;
      msg.textContent = '';
      // Review P1: recover a failed/empty alliance warm before the rerender rebuilds the pickers.
      (async () => {
        if (!alliancesCache) await ensureAlliances();
        await action();
      })()
        .then(() => rerenderCandidates())
        .catch((err) => {
          if (authRejected(err)) {
            window.location.replace('/leader'); // a granted Curator never 403s → session lapsed
            return;
          }
          msg.hidden = false; // reveal the role="alert" region BEFORE writing text
          msg.textContent = 'Couldn’t save that change. Please try again.';
          controls.forEach((c, i) => (c.disabled = prevDisabled[i]));
        })
        .finally(() => {
          writeInFlight = false;
        });
    };

    // --- Status lifecycle (Story 5.5) ---
    const actions = allowedActions(r.status);
    if (actions.length === 0) {
      const note = document.createElement('p');
      note.className = 'cand-actions-note';
      note.textContent = `This candidate is ${r.status} — no further status changes here.`;
      box.append(note);
    } else {
      // Accept (Applied): choosing a path both accepts AND sets the path in one write — an
      // Accept can never leave planned_path null (closes the "Accepted + null path" gap).
      if (actions.includes('accept')) {
        box.append(pathGroup('Accept as', null, (value) => run({ status: 'Accepted', planned_path: value })));
      }
      if (actions.includes('editPath')) {
        box.append(pathGroup('Planned path', r.planned_path, (value) => run({ planned_path: value })));
      }
      const btnRow = document.createElement('div');
      btnRow.className = 'cand-action-row';
      if (actions.includes('transfer')) {
        // Accepted → Transferred, and Applied → Transferred (the Random exception). Status
        // ONLY — no entry route to record (AR-19).
        const b = candButton('Mark Transferred', 'gold');
        b.addEventListener('click', () => run({ status: 'Transferred' }));
        btnRow.append(b);
      }
      if (actions.includes('reject')) {
        const b = candButton('Reject', 'danger');
        b.addEventListener('click', () => run({ status: 'Rejected' }));
        btnRow.append(b);
      }
      box.append(btnRow);
    }

    // --- Grouping + suggested alliance (Story 5.6) — orthogonal to status, always available ---
    box.append(buildSuggestSection(r, runTable));
    box.append(buildGroupSection(r, runTable));

    // --- Delete (Story 5.8) — any status, any time (FR-10). A two-step inline confirm guards the
    // one-click irreversible destroy (hard delete; the daily backup is the only recovery). No modal
    // (KISS — none in the component library). Routes through the table-wide runTable (a delete shifts
    // the counters + scope), which rerenders on success and drops the row.
    const del = document.createElement('div');
    del.className = 'cand-action-row cand-action-row--delete';
    const delBtn = candButton('Delete', 'danger');
    const restoreDelete = () => {
      del.textContent = '';
      del.append(delBtn);
    };
    delBtn.addEventListener('click', () => {
      del.textContent = '';
      const q = document.createElement('span');
      q.className = 'cand-action-label';
      q.textContent = 'Delete this candidate? This can’t be undone.';
      const yes = candButton('Confirm delete', 'danger');
      yes.addEventListener('click', () => runTable(() => deleteCandidateRow(r)));
      const no = candButton('Cancel', 'path');
      no.addEventListener('click', restoreDelete);
      del.append(q, yes, no);
    });
    del.append(delBtn);
    box.append(del);

    box.append(msg);
    return box;
  }

  // The write: session-authenticated PATCH; disable the row's buttons in-flight; on success
  // apply the patch to the local row and re-render in place (the load-once cache blocks a
  // refetch); 401/403 → the session lapsed → /leader; any other error → inline message + re-enable.
  async function writeCandidate(
    r: Candidate,
    patch: CandidatePatch,
    box: HTMLElement,
    msg: HTMLElement,
    onDone: () => void,
  ): Promise<void> {
    const btns = Array.from(box.querySelectorAll('button')) as HTMLButtonElement[];
    btns.forEach((b) => (b.disabled = true));
    msg.hidden = true;
    msg.textContent = '';
    try {
      await updateCandidate(r.id, patch); // echoes the row — used only to confirm success
      if ('status' in patch) r.status = patch.status as string;
      if ('planned_path' in patch) r.planned_path = (patch.planned_path ?? null) as string | null;
      onDone(); // re-render chip + path cell + actions from the mutated row
    } catch (err) {
      if (authRejected(err)) {
        window.location.replace('/leader'); // a granted Curator never 403s → session lapsed
        return;
      }
      msg.hidden = false; // reveal the role="alert" region BEFORE writing text so it reliably announces
      msg.textContent = 'Couldn’t save that change. Please try again.';
      btns.forEach((b) => (b.disabled = false));
    }
  }

  function renderCandidateTable(rows: Candidate[]) {
    const wrap = document.getElementById('cand-table-wrap');
    if (!wrap) return;
    wrap.textContent = '';

    // Story 5.7: the gold-framed capacity strip sits ABOVE the table, OUTSIDE the table's own
    // horizontal-scroll box (below) so a wide table scrolls under a fixed-width strip. Rebuilt every
    // render → counters recompute after each write for free (read-after-write, Task 5).
    wrap.append(buildCapStrip(rows, activePeriod));

    // Story 5.8: the Curator cleanup + reachability toolbar sits above the table (OUTSIDE the gold
    // cap-strip — danger red is reserved-out there). A Viewer never sees it. Built every render so
    // the terminal count + toggle state stay live. The .cleared confirmation shows after a cleanup.
    if (canWriteCandidates) wrap.append(buildCandToolbar(rows));
    if (cleanupNotice) wrap.append(buildClearedNotice());

    // Divergent flag + group membership derive over the FULL rows (a group can span in/out of the
    // active window); only the tbody iterates the scoped+sorted subset (AC-4 active-window scoping,
    // AC-5 carry-over-first). period == null degrades activeWindowRows to all rows (no blank table).
    const divergent = computeDivergentGroups(rows);
    // Story 5.8: the reachability toggle broadens the scope to ALL rows (prior-window applicants
    // included) so a Curator can reach + clear stranded leftovers; off → the 5.7 active-window set.
    const scoped = showClosedWindow ? rows : activeWindowRows(rows, activePeriod);
    const rendered = sortForWindow(scoped, activePeriod);
    // Prune expansion ids that scoped out of the rendered set so stale ids don't accumulate
    // (deferred-work L558/L218). Iterate a copy — openDetails is mutated in the loop.
    const renderedIds = new Set(rendered.map((r) => r.id));
    for (const id of Array.from(openDetails)) if (!renderedIds.has(id)) openDetails.delete(id);

    // Story 5.7 (review P2): the active window can be empty while candidateRows is not (a fresh window
    // with no new applications + no carry-overs). loadCandidates' empty state keys off candidateRows,
    // so surface a calm in-window note here instead of a bare header-only table.
    if (rendered.length === 0) {
      const note = document.createElement('p');
      note.className = 'cand-empty-note';
      note.textContent = activePeriod && !showClosedWindow
        ? 'No candidates in the active transfer window yet.'
        : 'No candidates to show.';
      wrap.append(note);
      return;
    }

    const scroll = document.createElement('div');
    scroll.className = 'cand-table-scroll'; // the horizontal-scroll box (AC4, 5.4) — wraps the table only

    const table = document.createElement('table');
    table.className = 'cand-table';

    const cols = ['Name', 'Player ID', 'Kingdom', 'Power', 'Timezone', 'Desired', 'Suggested', 'Status', 'Planned path'];
    const numCol = new Set([1, 2, 3]); // Player ID, Kingdom, Power → tabular, right-aligned
    const thead = document.createElement('thead');
    const htr = document.createElement('tr');
    cols.forEach((c, i) => {
      const th = document.createElement('th');
      th.scope = 'col';
      if (numCol.has(i)) th.className = 'num';
      th.textContent = c;
      htr.append(th);
    });
    thead.append(htr);
    table.append(thead);

    const tbody = document.createElement('tbody');
    rendered.forEach((r) => {
      const tr = document.createElement('tr');
      tr.className = 'cand-row';
      const inGroup = r.group != null;
      const isDivergent = inGroup && divergent.has(r.group as number);
      if (isDivergent) {
        tr.classList.add('cand-row--divergent');
        tr.title = 'Group has different suggested alliances — set one'; // non-colour affordance
      } else if (inGroup) {
        tr.classList.add('cand-row--group');
        tr.title = 'Linked transfer group';
      }

      // Name cell: expand toggle + name + optional special-invite badge
      const detailId = `cand-detail-${r.id}`;
      const isOpen = openDetails.has(r.id); // preserve expansion across a table-wide re-render
      const nameCell = document.createElement('td');
      nameCell.className = 'cand-name';
      const toggle = document.createElement('button');
      toggle.type = 'button';
      toggle.className = 'cand-expand';
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      toggle.setAttribute('aria-controls', detailId);
      toggle.setAttribute('aria-label', `Show details for ${r.character_name}`);
      toggle.textContent = '▸';
      if (isOpen) toggle.classList.add('cand-expand--open');
      nameCell.append(toggle, document.createTextNode(' ' + dash(r.character_name)));
      if (r.needs_special_invite) nameCell.append(specialBadge());
      if (isCarryOver(r, activePeriod)) nameCell.append(carryOverBadge()); // AC-5: derived, sorted first
      tr.append(nameCell);

      tr.append(td(dash(r.player_id), 'num'));
      tr.append(td(r.kingdom_number == null ? '—' : String(r.kingdom_number), 'num'));
      tr.append(td(fmtPower(r.power), 'num'));
      tr.append(td(dash(r.timezone)));
      tr.append(td(dash(r.desired_alliance?.name ?? null)));
      const suggCell = td(dash(r.suggested_alliance?.name ?? null));
      if (isDivergent) suggCell.append(divergentChip()); // compact danger marker (full copy in detail)
      tr.append(suggCell);

      const statusCell = document.createElement('td');
      statusCell.append(statusChip(r.status));
      tr.append(statusCell);

      const pathCell = td(dash(r.planned_path));
      tr.append(pathCell);
      tbody.append(tr);

      // Detail row — the remaining stored fields (FR-6 "all their fields"), read-only
      const dtr = document.createElement('tr');
      dtr.className = 'cand-detail';
      dtr.id = detailId;
      dtr.hidden = !isOpen;
      const dtd = document.createElement('td');
      dtd.colSpan = cols.length;

      // Divergent-group flag (Story 5.6) — visible to ALL leaders, edge-computed (AR-6), the
      // "N" recomputed on every render. Persists until one suggestion is chosen for the group.
      if (isDivergent) {
        const n = distinctSuggestionCount(rows, r.group as number);
        const flag = document.createElement('p');
        flag.className = 'cand-flag--divergent';
        const ic = document.createElement('span');
        ic.className = 'cand-flag-ic';
        ic.innerHTML = svg('triangle-alert'); // trusted constant SVG
        flag.append(ic, document.createTextNode(`Group has ${n} different suggested alliances — set one`));
        dtd.append(flag);
      }
      // Read-only transfer-group summary (visible to all; membership derived from candidates —
      // no transfer_groups read needed).
      if (inGroup) {
        const members = groupMembers(rows, r.group as number);
        const gsum = document.createElement('p');
        gsum.className = 'cand-group-summary';
        gsum.textContent = `Transfer group · ${members.length} member${members.length === 1 ? '' : 's'}: ${members
          .map((m) => m.character_name)
          .join(', ')}`;
        dtd.append(gsum);
      }

      const dl = document.createElement('dl');
      dl.className = 'cand-detail-list';
      const pairs: [string, string][] = [
        ['Who invited / knows them', dash(r.who_invited)],
        ['Why leaving', dash(r.why_leaving)],
        ['Team-player / KvK willing', yesNo(r.team_player_kvk)],
        ['Others transferring with', dash(r.others_transferring)],
        ['Day-4 FCFS ready', yesNo(r.day4_fcfs)],
        ['What they seek', dash(r.what_you_seek)],
        ['Players to avoid', dash(r.players_to_avoid)],
      ];
      for (const [k, v] of pairs) {
        const div = document.createElement('div');
        const dt = document.createElement('dt');
        dt.textContent = k;
        const dd = document.createElement('dd');
        dd.textContent = v;
        div.append(dt, dd);
        dl.append(div);
      }
      dtd.append(dl);

      // Curator status-lifecycle controls (Story 5.5) — only when the leader can write
      // (Owner or Transfer·Work). A Viewer sees the read-only detail exactly as in 5.4.
      // Story 5.7: a status/path write recomputes the WHOLE table (like the 5.6 group writes), not
      // just this row — a status change shifts the capacity counters and can move the row's
      // active-window scope (marking a carry-over Transferred scopes it out), so the strip + scope +
      // sort must recompute. rerenderCandidates rebuilds from the mutated rows and preserves expanded
      // rows via openDetails; focus-after-rerender stays the accepted 5.6 DF3 tradeoff (the
      // table-wide recompute is the chosen model — no refetch, the load-once cache blocks it anyway).
      const actionsHost = document.createElement('div');
      if (canWriteCandidates) {
        actionsHost.append(buildActions(r, rerenderCandidates));
        dtd.append(actionsHost);
      }

      dtr.append(dtd);
      tbody.append(dtr);

      toggle.addEventListener('click', () => {
        const open = dtr.hidden;
        dtr.hidden = !open;
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.classList.toggle('cand-expand--open', open);
        if (open) openDetails.add(r.id);
        else openDetails.delete(r.id); // remember expansion across a table-wide re-render
      });
    });

    table.append(tbody);
    scroll.append(table);
    wrap.append(scroll);
  }

  let candFetching = false;
  let candidatesLoaded = false;
  async function loadCandidates() {
    if (candFetching) return;
    candFetching = true;
    showCandState('loading');
    try {
      const rows = await getCandidates();
      candidateRows = rows ?? []; // held module-wide so 5.6/5.7 writes can recompute the table
      cleanupNotice = null; // a fresh load supersedes any prior cleanup confirmation (Story 5.8)
      // Story 5.7: fetch the active window's caps alongside the candidates (one fetch per shell load,
      // AD-4). A transient failure here must NOT fail the whole list or cache zeroed caps — that
      // would freeze every denominator at n/0 for the session (Task 6, mirroring the 5.6
      // ensureAlliances no-cache-on-failure lesson). Degrade to null so counts still show with a "—"
      // denominator + a calm note; a 401/403 rethrows to the outer catch → /leader (a granted leader
      // never 403s here → the session lapsed).
      activePeriod = null;
      capsReadError = false;
      try {
        activePeriod = await getActivePeriod();
      } catch (perr) {
        if (authRejected(perr)) throw perr;
        capsReadError = true;
      }
      // Warm the suggested-alliance picker so the per-row controls build synchronously (a
      // Curator already holds the free alliances read; a Viewer builds no controls).
      if (canWriteCandidates) await ensureAlliances();
      if (candidateRows.length === 0) {
        showCandState('empty');
      } else {
        renderCandidateTable(candidateRows);
        showCandState('table');
      }
      candidatesLoaded = true; // success — don't auto-refetch on tab re-activation
    } catch (err) {
      if (authRejected(err)) {
        window.location.replace('/leader'); // session lapsed (a granted viewer never 403s here)
        return;
      }
      showCandState('error'); // reachability failure — Retry offered
    } finally {
      candFetching = false;
    }
  }
  function maybeLoadCandidates() {
    if (candidatesLoaded || candFetching) return;
    loadCandidates();
  }

  // ===== Guides panel (Story 6.3) — the Senior/Owner publish surface =====
  // Publish = copy a guide_drafts row VERBATIM into `guides` (create-or-update by slug) via
  // publishGuide(). The server enforces WHO (an Editor/Viewer gets a real 403 on `guides` —
  // the Option-2 collection-boundary gate); this panel only guides UX (AD-4). Authoring
  // stays in the Data Studio (AD-3) — no WYSIWYG, no editing, no body preview here. All
  // draft data enters the DOM via textContent; body HTML is NEVER rendered in the shell.
  let canPublishGuides = false; // set in boot(): Owner OR a `guides` write grant (Guides·Work)
  let guideDrafts: GuideDraft[] = [];
  let publishedGuides: PublishedGuide[] = [];
  let guidesLoaded = false;
  let guidesFetching = false;

  function showGuidesState(which: 'loading' | 'error' | 'empty' | 'table') {
    const map: Record<string, string> = {
      loading: 'guides-loading',
      error: 'guides-error',
      empty: 'guides-empty',
      table: 'guides-table-wrap',
    };
    for (const [key, elId] of Object.entries(map)) {
      const el = document.getElementById(elId);
      if (el) el.hidden = key !== which;
    }
  }

  // The derived per-draft publish state — a pure edge computation over the two in-memory
  // lists, never stored (AD-4): no `guides` row with the draft's slug → the draft is
  // unpublished; a row exists and is at least as new as the draft → published; the draft
  // is newer → published with unpublished edits pending re-publish. Timestamps are
  // ISO-8601 UTC; a never-updated row falls back to its creation stamp. Ties (the copy is
  // written moments AFTER the draft's last save) count as published — only a draft edit
  // AFTER the publish flips it back to 'draft-newer'.
  type GuideState = 'draft-only' | 'published' | 'draft-newer';
  function effectiveStamp(dateUpdated: string | null, dateCreated: string | null): number {
    const s = dateUpdated ?? dateCreated;
    const t = s ? Date.parse(s) : NaN;
    return Number.isNaN(t) ? 0 : t;
  }
  function guideState(draft: GuideDraft, published: PublishedGuide[]): GuideState {
    const match = published.find((g) => g.slug === draft.slug);
    if (!match) return 'draft-only';
    return effectiveStamp(draft.date_updated, draft.date_created) >
      effectiveStamp(match.date_updated, match.date_created)
      ? 'draft-newer'
      : 'published';
  }

  function guideStateChip(state: GuideState): HTMLElement {
    const chip = document.createElement('span');
    const cls: Record<GuideState, string> = {
      'draft-only': 'badge-status badge-status--applied',
      published: 'badge-status badge-status--accepted',
      'draft-newer': 'badge-status badge-status--draft-newer',
    };
    const label: Record<GuideState, string> = {
      'draft-only': 'Draft',
      published: 'Published',
      'draft-newer': 'Draft newer',
    };
    chip.className = cls[state];
    chip.textContent = label[state]; // the word carries meaning beyond colour (a11y)
    return chip;
  }

  const isoDay = (s: string | null): string => (s ? s.slice(0, 10) : '—');

  async function loadGuides() {
    if (guidesFetching) return;
    guidesFetching = true;
    showGuidesState('loading');
    try {
      // Both reads are wired since 6.1 (guides-viewer/-senior hold guide_drafts + guides
      // read). The published list carries only slug + timestamps — never content.
      const [drafts, published] = await Promise.all([getGuideDrafts(), getPublishedGuides()]);
      guideDrafts = drafts ?? [];
      publishedGuides = published ?? [];
      if (guideDrafts.length === 0) {
        showGuidesState('empty');
      } else {
        renderGuidesTable();
        showGuidesState('table');
      }
      guidesLoaded = true; // success — don't auto-refetch on tab re-activation (load-once, mirror 5.4)
    } catch (err) {
      if (authRejected(err)) {
        window.location.replace('/leader'); // session lapsed (a granted leader never 403s here)
        return;
      }
      showGuidesState('error');
    } finally {
      guidesFetching = false;
    }
  }
  function maybeLoadGuides() {
    if (guidesLoaded || guidesFetching) return;
    loadGuides();
  }

  function buildPublishCell(draft: GuideDraft, state: GuideState): HTMLTableCellElement {
    const cell = document.createElement('td');
    cell.className = 'guide-publish-cell';
    const msg = document.createElement('p');
    msg.className = 'cand-action-msg';
    msg.setAttribute('role', 'alert');
    msg.hidden = true;
    const btn = candButton(state === 'draft-only' ? 'Publish' : 'Re-publish', 'gold');
    if (state === 'published') {
      // Published and up to date — a re-publish would be a redundant no-op copy (the 5.5
      // review-P1 lesson: disable the no-op control instead of letting it flash the row).
      btn.disabled = true;
      btn.title = 'Published and up to date — edit the draft to re-publish';
    }
    btn.addEventListener('click', () => doPublish(draft, btn, msg));
    cell.append(btn, msg);
    return cell;
  }

  async function doPublish(draft: GuideDraft, btn: HTMLButtonElement, msg: HTMLElement) {
    if (writeInFlight || btn.disabled) return; // one module-wide write guard (5.6 review P3)
    writeInFlight = true;
    const prevLabel = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Publishing…';
    msg.hidden = true;
    msg.textContent = '';
    try {
      // Re-read the draft at click time (review P1): the panel list is load-once, and an
      // Editor may have saved newer content in the Studio since — the copy must publish
      // the CURRENT draft, never the cached one. Also keeps the row's Updated cell honest.
      const fresh = await getGuideDraft(draft.id);
      const idx = guideDrafts.findIndex((d) => d.id === draft.id);
      if (idx !== -1) guideDrafts[idx] = fresh;
      const existing = publishedGuides.find((g) => g.slug === fresh.slug);
      const saved = await publishGuide(fresh, existing?.id);
      // Read-after-write on the in-memory published list: the echoed row carries the
      // server stamps (the Senior holds the guides read). Defensive fallbacks keep the
      // chip truthful even if a proxy strips the echo body.
      if (existing) {
        existing.date_updated = saved?.date_updated ?? new Date().toISOString();
      } else if (saved?.id != null) {
        publishedGuides.push({
          id: saved.id,
          slug: saved.slug ?? fresh.slug,
          date_created: saved.date_created ?? new Date().toISOString(),
          date_updated: saved.date_updated ?? null,
        });
      } else {
        // Create succeeded but the echo was stripped (review P2) — never invent an id
        // (a fake update target would break the next re-publish); drop load-once and
        // re-sync both lists from the server instead.
        guidesLoaded = false;
        loadGuides();
        return;
      }
      renderGuidesTable(); // re-derive the state chips in place — no refetch, no reload
    } catch (err) {
      if (authRejected(err)) {
        window.location.replace('/leader');
        return;
      }
      msg.hidden = false; // reveal the role="alert" region BEFORE writing text (5.5 review P2)
      msg.textContent = 'Couldn’t publish. Please try again.';
      btn.disabled = false;
      btn.textContent = prevLabel;
    } finally {
      writeInFlight = false;
    }
  }

  function renderGuidesTable() {
    const wrap = document.getElementById('guides-table-wrap');
    if (!wrap) return;
    wrap.textContent = '';

    const scroll = document.createElement('div');
    scroll.className = 'cand-table-scroll'; // wide table scrolls in its own box, never the page

    const table = document.createElement('table');
    table.className = 'cand-table';

    const cols = ['Title', 'Slug', 'Category', 'Updated', 'State'];
    if (canPublishGuides) cols.push('Publish');
    const thead = document.createElement('thead');
    const htr = document.createElement('tr');
    for (const c of cols) {
      const th = document.createElement('th');
      th.scope = 'col';
      th.textContent = c;
      htr.append(th);
    }
    thead.append(htr);
    table.append(thead);

    const tbody = document.createElement('tbody');
    for (const d of guideDrafts) {
      const tr = document.createElement('tr');
      tr.append(td(dash(d.title)));
      tr.append(td(d.slug, 'guide-slug')); // the immutable public address (join key)
      tr.append(td(dash(d.category?.name ?? null)));
      tr.append(td(isoDay(d.date_updated ?? d.date_created)));
      const st = guideState(d, publishedGuides);
      const stateCell = document.createElement('td');
      stateCell.append(guideStateChip(st));
      tr.append(stateCell);
      if (canPublishGuides) tr.append(buildPublishCell(d, st));
      tbody.append(tr);
    }
    table.append(tbody);
    scroll.append(table);
    wrap.append(scroll);
  }

  async function doLogout(btn: HTMLButtonElement) {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Signing out…';
    try {
      await logout();
    } catch (err) {
      // A live cookie after a failed logout (network/CORS) must not falsely sign the leader
      // out on a shared machine — stay put and let them retry. A 401 = already gone → proceed.
      if (!authRejected(err)) {
        // Surface the failure — a silent no-op reads as "signed out" while the session is live.
        btn.textContent = 'Couldn’t sign out — try again';
        btn.disabled = false;
        return;
      }
    }
    window.location.replace('/leader'); // success (or already-gone 401) → back to login
  }

  async function boot() {
    showOnly(loadingEl);
    try {
      const user = await getCurrentUser(); // 401 here → not signed in
      void user;
    } catch (err) {
      if (authRejected(err)) {
        window.location.replace('/leader'); // gate: sign in first
        return;
      }
      showOnly(errorEl); // backend unreachable — offer retry
      return;
    }

    let isOwner = false;
    let accessible: ResolvedArea[] = [];
    try {
      isOwner = await getAdminAccess();
      if (isOwner) {
        accessible = AREAS.map((a) => ({ ...a, mode: 'all' }));
      } else {
        accessible = resolveNonOwnerAreas(await getMyPermissions());
      }
    } catch {
      showOnly(errorEl);
      return;
    }

    renderChips(accessible, isOwner);
    // Story 5.5: gate the per-row status/path controls on write capability. Owner (admin
    // bypass) or a Curator whose Transfer area resolved to 'Work' (holds the update grant).
    canWriteCandidates = isOwner || accessible.some((a) => a.key === 'candidates' && a.mode === 'Work');
    // Story 6.3: gate the per-row Publish controls the same way — Owner, or a Senior whose
    // Guides area resolved to 'Work' (holds the 6.3 `guides` create/update grants). A
    // leader whose union carries a `guides` READ (guides-viewer) sees the list with no
    // controls; a pure guides-editor holds NO `guides` grant at all, so the tab itself is
    // absent (the 3.5 area keying) — their surface is the Studio. Server 403s regardless.
    canPublishGuides = isOwner || accessible.some((a) => a.key === 'guides' && a.mode === 'Work');

    if (accessible.length === 0) {
      showOnly(emptyEl); // signed in, no area granted yet
      return;
    }

    renderShell(accessible);
    showOnly(shellEl);
  }

  // In-flight guard: a second boot (a double-clicked Retry, or a Retry during the initial
  // load) must not race the first — interleaved runs can clear-then-append the tab strip
  // out of order and double the tabs/chips.
  let booting = false;
  function runBoot() {
    if (booting) return;
    booting = true;
    boot().finally(() => { booting = false; });
  }

  document.getElementById('admin-retry')?.addEventListener('click', () => runBoot());
  document
    .getElementById('admin-logout')
    ?.addEventListener('click', (e) => doLogout(e.currentTarget as HTMLButtonElement));
  document
    .getElementById('admin-empty-logout')
    ?.addEventListener('click', (e) => doLogout(e.currentTarget as HTMLButtonElement));

  // Candidates/Guides Retry — delegated on the static #admin-panels (the buttons are built per-render).
  panelsEl?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement)?.closest?.('#cand-retry')) loadCandidates();
    if ((e.target as HTMLElement)?.closest?.('#guides-retry')) loadGuides();
  });

  runBoot();
</script>
