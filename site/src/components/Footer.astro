---
/*
  Site footer (Story 1.3). The IP disclaimer is the only required element
  (UX-DR-6) — verbatim text, em-dash. The link row mirrors the mockup and is
  cheap; it reuses the nav-item shape but keeps its own small array (footer is a
  separate consumer; no premature extraction — Rule of Three).
*/
import Icon from './Icon.astro';

const links = [
  { label: 'Tools', href: '/tools' },
  { label: 'Alliance Finder', href: '/finder' },
  { label: 'Guides', href: '/guides' },
  { label: 'Join 1516', href: '/join' },
];

// Donations stay strictly cost-covering (keeps the unofficial-fan-site posture).
// PLACEHOLDER handle — swap for the real Ko-fi page before launch (cutover checklist).
const COFFEE_URL = 'https://ko-fi.com/PLACEHOLDER-kingdom1516';
---

<footer class="site-footer">
  <p class="disclaimer">Unofficial fan site — not affiliated with or endorsed by Century Games.</p>
  <nav class="footer-links" aria-label="Footer">
    {links.map((l, i) => (
      <Fragment>
        {i > 0 && <span class="sep" aria-hidden="true">·</span>}
        <a href={l.href}>{l.label}</a>
      </Fragment>
    ))}
  </nav>
  <p class="support">
    <a href={COFFEE_URL} target="_blank" rel="noopener noreferrer">
      <Icon name="coffee" /> Buy me a coffee — helps keep the server &amp; domain running
    </a>
  </p>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-4);
    padding: var(--space-6) var(--space-7);
    border-top: 2px solid var(--color-primary);
    background: linear-gradient(#F6EDD7, #FDF9EF);
    text-align: center;
  }
  /* Dark "Royal Court": the light-parchment gradient has no dark variant, but
     --color-muted/--color-accent text flips to light — remap the surface. */
  :global(:root[data-theme="dark"]) .site-footer {
    background: linear-gradient(var(--color-bg), var(--color-surface));
  }
  .disclaimer {
    font-size: 12.5px;
    color: var(--color-muted);
    margin: 0;
  }
  .footer-links {
    margin-top: var(--space-2);
    font-size: 12px;
  }
  .footer-links a {
    color: var(--color-accent);
    margin: 0 var(--space-2);
    text-decoration: none;
  }
  .footer-links a:hover {
    text-decoration: underline;
  }
  .footer-links .sep {
    color: var(--color-border);
  }
  .support {
    margin: var(--space-3) 0 0;
    font-size: 12px;
  }
  .support a {
    color: var(--color-muted);
    text-decoration: none;
  }
  .support a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
