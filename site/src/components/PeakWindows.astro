---
import Icon from './Icon.astro';
---

{/*
  Personal peak-window input (Story 2.5). Sits next to the timezone control —
  windows are read in the visitor's LOCAL time, so they belong with the tz row.
  One empty row is server-rendered (no-JS honesty: inert inputs that do nothing
  with JS off, never a broken/blocking state). The finder client script
  (src/scripts/finder/index.ts) wires add/remove, validation, persistence, and
  windows-aware re-ranking. The remove <button> ships hidden on this first row;
  new rows clone it (carrying the inline Lucide "x" SVG — one icon mechanism, no
  emoji).
*/}
<section class="peak-row" aria-labelledby="peak-q">
  <div class="peak-head">
    <span class="peak-ic" aria-hidden="true"><Icon name="clock" /></span>
    <div class="peak-head-text">
      <p class="peak-q" id="peak-q">When are you usually active?</p>
      <p class="peak-hint">Optional — leave empty to use the standard evening.</p>
    </div>
  </div>
  <div class="peak-windows" id="peak-windows">
    <div class="peak-window" data-peak-window>
      <div class="peak-fields">
        <input type="time" class="peak-input" data-peak-start aria-label="Active window start time" />
        <span class="peak-dash" aria-hidden="true">–</span>
        <input type="time" class="peak-input" data-peak-end aria-label="Active window end time" />
        <button type="button" class="peak-remove" data-peak-remove hidden aria-label="Remove this window"><Icon name="x" /></button>
      </div>
      <p class="peak-error" data-peak-error hidden></p>
    </div>
  </div>
  <button type="button" class="peak-add" id="peak-add">
    <span class="peak-add-ic" aria-hidden="true"><Icon name="plus" /></span>add window
  </button>
</section>

<style>
  /* Backgrounds use role tokens only, so both themes flip automatically: no baked
     light gradient → no dark variant needed (the 1.3/1.4 wash-out guard is honored
     by avoiding the problem). */
  .peak-row {
    margin: 0 0 var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .peak-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .peak-ic {
    flex: none;
    margin-top: 2px;
    color: var(--color-primary-hover);
    display: inline-flex;
  }
  .peak-q {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }
  .peak-hint {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }
  .peak-windows {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .peak-window {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .peak-fields {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .peak-input {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-ink);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    padding: var(--space-2) var(--space-3);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }
  .peak-input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .peak-dash {
    color: var(--color-muted);
    font-size: 14px;
  }
  .peak-remove {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    cursor: pointer;
    font-size: 15px;
  }
  .peak-remove[hidden] {
    display: none;
  }
  .peak-remove:hover {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-muted) 12%, transparent);
  }
  .peak-remove:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .peak-error {
    font-size: 12px;
    color: var(--color-primary-hover);
    margin: 0;
  }
  .peak-error[hidden] {
    display: none;
  }
  .peak-add {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    border-radius: 7px;
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
  }
  .peak-add-ic {
    display: inline-flex;
    font-size: 15px;
  }
  .peak-add:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .peak-add:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 767.98px) {
    .peak-input {
      flex: 1 1 auto;
    }
  }
</style>
